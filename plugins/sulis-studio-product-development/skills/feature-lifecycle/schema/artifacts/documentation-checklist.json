{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-documentation-checklist",
  "title": "DOCUMENTATION_CHECKLIST.md Artifact Schema",
  "description": "Required checklist for evaluating all documentation triggers during COMPLETION phase",
  "type": "object",
  "required": ["sections", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "documentation_checklist"
    },
    "file_pattern": {
      "type": "string",
      "const": "DOCUMENTATION_CHECKLIST.md"
    },
    "sections": {
      "type": "object",
      "required": ["header", "platform_conventions", "docs_folder", "readme", "feature_index", "summary"],
      "properties": {
        "header": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "title": { "type": "string", "const": "# Documentation Checklist" },
            "feature_name": { "type": "string" },
            "evaluated_at": { "type": "string", "format": "date-time" },
            "evaluated_by": { "type": "string" }
          }
        },
        "platform_conventions": {
          "type": "object",
          "required": ["present", "triggers"],
          "description": "Evaluation of all 14 PLATFORM_CONVENTIONS.md triggers",
          "properties": {
            "present": { "type": "boolean" },
            "section_title": { "type": "string", "const": "## PLATFORM_CONVENTIONS.md Triggers" },
            "triggers": {
              "type": "array",
              "minItems": 14,
              "maxItems": 14,
              "items": {
                "type": "object",
                "required": ["trigger_id", "trigger_name", "section", "evaluated", "action"],
                "properties": {
                  "trigger_id": {
                    "type": "string",
                    "pattern": "^PC-[0-9]{2}$",
                    "description": "Trigger ID (PC-01 to PC-14)"
                  },
                  "trigger_name": {
                    "type": "string",
                    "enum": [
                      "New entity ID prefix",
                      "New API endpoint pattern",
                      "New query parameter convention",
                      "New JSON field naming",
                      "New permission pattern",
                      "New authorization pattern",
                      "New identity type",
                      "New interaction level",
                      "New entity structure",
                      "New lifecycle/status values",
                      "New state machine pattern",
                      "New storage abstraction",
                      "New error handling pattern",
                      "New ServiceSpec pattern"
                    ]
                  },
                  "section": {
                    "type": "string",
                    "description": "PLATFORM_CONVENTIONS.md section number"
                  },
                  "evaluated": {
                    "type": "boolean",
                    "const": true,
                    "description": "Must be true - trigger was evaluated"
                  },
                  "action": {
                    "type": "string",
                    "enum": ["updated", "not_applicable"]
                  },
                  "update_description": {
                    "type": "string",
                    "description": "What was added/changed (if action=updated)"
                  },
                  "justification": {
                    "type": "string",
                    "description": "REQUIRED if action=not_applicable"
                  }
                }
              }
            },
            "file_updated": { "type": "boolean" },
            "sections_modified": {
              "type": "array",
              "items": { "type": "string" }
            },
            "changelog_entry_added": { "type": "boolean" }
          }
        },
        "docs_folder": {
          "type": "object",
          "required": ["present", "triggers"],
          "description": "Evaluation of all 6 /docs folder triggers",
          "properties": {
            "present": { "type": "boolean" },
            "section_title": { "type": "string", "const": "## /docs Folder Triggers" },
            "triggers": {
              "type": "array",
              "minItems": 6,
              "maxItems": 6,
              "items": {
                "type": "object",
                "required": ["trigger_id", "trigger_name", "evaluated", "action"],
                "properties": {
                  "trigger_id": {
                    "type": "string",
                    "pattern": "^DOC-[0-9]{2}$",
                    "description": "Trigger ID (DOC-01 to DOC-06)"
                  },
                  "trigger_name": {
                    "type": "string",
                    "enum": [
                      "User-facing API endpoints",
                      "New configuration options",
                      "New concepts/terminology",
                      "New workflows/processes",
                      "Security-relevant changes",
                      "Breaking changes"
                    ]
                  },
                  "evaluated": {
                    "type": "boolean",
                    "const": true,
                    "description": "Must be true - trigger was evaluated"
                  },
                  "action": {
                    "type": "string",
                    "enum": ["created", "updated", "not_applicable"]
                  },
                  "file_path": {
                    "type": "string",
                    "description": "Path to created/updated file (if action != not_applicable)"
                  },
                  "description": {
                    "type": "string",
                    "description": "What was documented"
                  },
                  "justification": {
                    "type": "string",
                    "description": "REQUIRED if action=not_applicable"
                  }
                }
              }
            },
            "files_created": {
              "type": "array",
              "items": { "type": "string" }
            },
            "files_modified": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "readme": {
          "type": "object",
          "required": ["present", "evaluated"],
          "properties": {
            "present": { "type": "boolean" },
            "section_title": { "type": "string", "const": "## README.md Evaluation" },
            "evaluated": {
              "type": "boolean",
              "const": true
            },
            "needs_update": { "type": "boolean" },
            "updated": { "type": "boolean" },
            "justification": {
              "type": "string",
              "description": "Why README does/doesn't need update"
            }
          }
        },
        "feature_index": {
          "type": "object",
          "required": ["present", "updated"],
          "properties": {
            "present": { "type": "boolean" },
            "section_title": { "type": "string", "const": "## Feature Index" },
            "updated": {
              "type": "boolean",
              "const": true,
              "description": "features/index.md must be updated"
            },
            "status_set_to_complete": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "summary": {
          "type": "object",
          "required": ["present", "totals"],
          "properties": {
            "present": { "type": "boolean" },
            "section_title": { "type": "string", "const": "## Summary" },
            "totals": {
              "type": "object",
              "required": ["platform_conventions_triggers", "docs_triggers", "total_updates"],
              "properties": {
                "platform_conventions_triggers": {
                  "type": "object",
                  "properties": {
                    "evaluated": { "type": "integer", "const": 14 },
                    "updated": { "type": "integer" },
                    "not_applicable": { "type": "integer" }
                  }
                },
                "docs_triggers": {
                  "type": "object",
                  "properties": {
                    "evaluated": { "type": "integer", "const": 6 },
                    "created": { "type": "integer" },
                    "updated": { "type": "integer" },
                    "not_applicable": { "type": "integer" }
                  }
                },
                "total_updates": {
                  "type": "integer",
                  "description": "Total documentation files created or modified"
                }
              }
            },
            "all_triggers_evaluated": {
              "type": "boolean",
              "const": true,
              "description": "Verification that all 20 triggers were evaluated"
            },
            "documentation_complete": {
              "type": "boolean",
              "description": "True if all required documentation was completed"
            }
          }
        }
      }
    },
    "trigger_definitions": {
      "type": "object",
      "description": "Reference definitions for all triggers",
      "properties": {
        "platform_conventions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "section": { "type": "string" },
              "description": { "type": "string" },
              "examples": { "type": "array", "items": { "type": "string" } }
            }
          },
          "default": [
            { "id": "PC-01", "name": "New entity ID prefix", "section": "1.8", "description": "Adding a new entity ID prefix pattern", "examples": ["shr_ for sharing grants", "org_ for organizations"] },
            { "id": "PC-02", "name": "New API endpoint pattern", "section": "1.3", "description": "New URL path patterns or conventions", "examples": ["/api/v1/{resource}/{id}/share", "/api/v1/{resource}/{id}/members"] },
            { "id": "PC-03", "name": "New query parameter convention", "section": "1.5", "description": "New query parameter naming or usage", "examples": ["?grantType=view", "?memberRole=admin"] },
            { "id": "PC-04", "name": "New JSON field naming", "section": "1.4", "description": "New JSON field patterns", "examples": ["grantedAt timestamp", "interactionLevel enum"] },
            { "id": "PC-05", "name": "New permission pattern", "section": "4.2", "description": "New permission string patterns", "examples": ["domain.entity:share", "*.groups:manage"] },
            { "id": "PC-06", "name": "New authorization pattern", "section": "4", "description": "Changes to authorization model", "examples": ["Three-layer auth (service/platform/policy)", "DAC sharing model"] },
            { "id": "PC-07", "name": "New identity type", "section": "3.3", "description": "New types of identities", "examples": ["Service identities", "Group identities"] },
            { "id": "PC-08", "name": "New interaction level", "section": "3.2", "description": "New interaction level definitions", "examples": ["Organization-level interactions", "Cross-platform sharing"] },
            { "id": "PC-09", "name": "New entity structure", "section": "3.1", "description": "New sys/data entity patterns", "examples": ["SharingGrant with sys/data split", "OrganizationGroup structure"] },
            { "id": "PC-10", "name": "New lifecycle/status values", "section": "6", "description": "New status enums or lifecycle states", "examples": ["AccessRequestStatus values", "SharingGrantStatus values"] },
            { "id": "PC-11", "name": "New state machine pattern", "section": "7", "description": "New workflow or state machine", "examples": ["Access request workflow", "Sharing approval flow"] },
            { "id": "PC-12", "name": "New storage abstraction", "section": "8", "description": "New storage patterns or providers", "examples": ["SharingGrantRepository", "AccessRequestRepository"] },
            { "id": "PC-13", "name": "New error handling pattern", "section": "9", "description": "New error codes or handling patterns", "examples": ["SHARING_LIMIT_EXCEEDED", "INTERACTION_BLOCKED"] },
            { "id": "PC-14", "name": "New ServiceSpec pattern", "section": "5", "description": "New ServiceSpec or configuration patterns", "examples": ["Sharing policy configuration", "Organization settings"] }
          ]
        },
        "docs_folder": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "file_suggestion": { "type": "string" }
            }
          },
          "default": [
            { "id": "DOC-01", "name": "User-facing API endpoints", "description": "New APIs that users will call", "file_suggestion": "docs/api/{feature}.md" },
            { "id": "DOC-02", "name": "New configuration options", "description": "Settings users can configure", "file_suggestion": "docs/configuration.md" },
            { "id": "DOC-03", "name": "New concepts/terminology", "description": "New terms users need to understand", "file_suggestion": "docs/concepts/{concept}.md" },
            { "id": "DOC-04", "name": "New workflows/processes", "description": "Multi-step user workflows", "file_suggestion": "docs/guides/{workflow}.md" },
            { "id": "DOC-05", "name": "Security-relevant changes", "description": "Authentication, authorization, data protection", "file_suggestion": "docs/security.md" },
            { "id": "DOC-06", "name": "Breaking changes", "description": "Changes that affect existing users", "file_suggestion": "docs/migration/{version}.md" }
          ]
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "all_triggers_evaluated": {
          "type": "boolean",
          "const": true,
          "description": "All 20 triggers (14 PC + 6 DOC) must be evaluated"
        },
        "no_empty_justifications": {
          "type": "boolean",
          "const": true,
          "description": "Every not_applicable action must have justification"
        },
        "feature_index_updated": {
          "type": "boolean",
          "const": true,
          "description": "features/index.md must be updated"
        },
        "changelog_updated_if_platform_conventions_changed": {
          "type": "boolean",
          "description": "If PLATFORM_CONVENTIONS.md was updated, changelog entry required"
        }
      }
    },
    "markdown_format": {
      "type": "object",
      "description": "Expected markdown structure for the checklist",
      "properties": {
        "template": {
          "type": "string",
          "const": "# Documentation Checklist\n\n**Feature:** {feature_name}\n**Evaluated:** {date}\n**By:** {evaluator}\n\n## PLATFORM_CONVENTIONS.md Triggers\n\n| ID | Trigger | Section | Action | Details |\n|----|---------|---------|--------|--------|\n| PC-01 | New entity ID prefix | 1.8 | {action} | {details} |\n| ... | ... | ... | ... | ... |\n\n**File Updated:** {yes/no}\n**Sections Modified:** {list}\n**Changelog Entry Added:** {yes/no}\n\n## /docs Folder Triggers\n\n| ID | Trigger | Action | File | Details |\n|----|---------|--------|------|--------|\n| DOC-01 | User-facing API endpoints | {action} | {file} | {details} |\n| ... | ... | ... | ... | ... |\n\n**Files Created:** {list}\n**Files Modified:** {list}\n\n## README.md Evaluation\n\n- Evaluated: Yes\n- Needs Update: {yes/no}\n- Updated: {yes/no}\n- Justification: {reason}\n\n## Feature Index\n\n- Updated: Yes\n- Status Set to Complete: Yes\n\n## Summary\n\n| Category | Evaluated | Updated | Not Applicable |\n|----------|-----------|---------|----------------|\n| PLATFORM_CONVENTIONS.md | 14 | {n} | {m} |\n| /docs Folder | 6 | {n} | {m} |\n\n**All Triggers Evaluated:** Yes\n**Documentation Complete:** {yes/no}"
        }
      }
    }
  }
}
