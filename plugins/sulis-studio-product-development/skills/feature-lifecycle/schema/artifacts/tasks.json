{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-tasks",
  "title": "TASKS.md Artifact Schema",
  "description": "Required sections and content for Task Checklist document",
  "type": "object",
  "required": ["sections", "task_format", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "tasks"
    },
    "file_pattern": {
      "type": "string",
      "const": "TASKS.md"
    },
    "sections": {
      "type": "object",
      "required": ["overview", "progress", "tasks", "session_notes"],
      "properties": {
        "overview": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "properties": {
                "feature_reference": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Link to PLAN.md and DESIGN.md" }
                  }
                },
                "last_updated": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Timestamp of last update" }
                  }
                }
              }
            }
          }
        },
        "progress": {
          "type": "object",
          "required": ["present", "has_metrics"],
          "properties": {
            "present": { "type": "boolean" },
            "has_metrics": { "type": "boolean" },
            "description": { "type": "string", "const": "Progress metrics (X/Y tasks, percentage)" },
            "format": {
              "type": "object",
              "properties": {
                "completed": { "type": "integer" },
                "total": { "type": "integer" },
                "percentage": { "type": "number" }
              }
            }
          }
        },
        "tasks": {
          "type": "object",
          "required": ["present", "grouped_by_phase"],
          "properties": {
            "present": { "type": "boolean" },
            "grouped_by_phase": { "type": "boolean" },
            "description": { "type": "string", "const": "Tasks grouped by implementation phase" }
          }
        },
        "blockers": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Current blockers and their status" }
          }
        },
        "session_notes": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Notes from each work session for context continuity" }
          }
        }
      }
    },
    "task_format": {
      "type": "object",
      "description": "Format for individual tasks",
      "required": ["status_markers", "required_fields"],
      "properties": {
        "status_markers": {
          "type": "object",
          "properties": {
            "pending": { "type": "string", "const": "[ ]" },
            "in_progress": { "type": "string", "const": "[→]" },
            "completed": { "type": "string", "const": "[✓]" },
            "blocked": { "type": "string", "const": "[✗]" },
            "skipped": { "type": "string", "const": "[~]" }
          }
        },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["status", "description"]
        },
        "optional_fields": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["timestamp", "notes", "blocker_ref"]
        },
        "example": {
          "type": "string",
          "const": "[✓] 2025-12-27 10:30 - Implement domain model for SharingGrant"
        }
      }
    },
    "session_note_format": {
      "type": "object",
      "description": "Format for session notes",
      "required": ["required_fields"],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["date", "summary"]
        },
        "optional_fields": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["discoveries", "decisions", "blockers_encountered", "next_session_start"]
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "all_tasks_have_status": {
          "type": "boolean",
          "const": true,
          "description": "Every task must have a status marker"
        },
        "completed_tasks_have_timestamp": {
          "type": "boolean",
          "const": true,
          "description": "Completed tasks must have timestamp"
        },
        "one_in_progress_max": {
          "type": "boolean",
          "const": true,
          "description": "At most one task can be in_progress at a time"
        },
        "references_plan": {
          "type": "boolean",
          "const": true,
          "description": "Must reference PLAN.md phases"
        }
      }
    }
  }
}
