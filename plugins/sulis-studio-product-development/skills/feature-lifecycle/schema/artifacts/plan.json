{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-plan",
  "title": "PLAN.md Artifact Schema",
  "description": "Required sections and content for Implementation Plan document",
  "type": "object",
  "required": ["sections", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "plan"
    },
    "file_pattern": {
      "type": "string",
      "const": "PLAN.md"
    },
    "sections": {
      "type": "object",
      "required": ["overview", "approach", "phases", "risks"],
      "properties": {
        "overview": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["objective", "scope"],
              "properties": {
                "objective": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What this implementation achieves" }
                  }
                },
                "scope": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What is in/out of scope for this implementation" }
                  }
                },
                "dependencies": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "External dependencies and prerequisites" }
                  }
                }
              }
            }
          }
        },
        "approach": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["strategy", "tdd_approach"],
              "properties": {
                "strategy": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Overall implementation strategy" }
                  }
                },
                "tdd_approach": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "How TDD will be applied (double-loop)" }
                  }
                },
                "component_order": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Order of component implementation" }
                  }
                }
              }
            }
          }
        },
        "phases": {
          "type": "object",
          "required": ["present", "min_phases"],
          "properties": {
            "present": { "type": "boolean" },
            "min_phases": { "type": "integer", "default": 2 },
            "description": { "type": "string", "const": "Implementation phases with deliverables" },
            "phase_format": {
              "type": "object",
              "required": ["name", "description", "deliverables"],
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "deliverables": { "type": "array", "items": { "type": "string" } },
                "verification": { "type": "string" }
              }
            }
          }
        },
        "risks": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Implementation risks and mitigations" }
          }
        },
        "verification": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "How implementation will be verified against IVS" }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "references_design": {
          "type": "boolean",
          "const": true,
          "description": "Must reference DESIGN.md"
        },
        "references_ivs": {
          "type": "boolean",
          "const": true,
          "description": "Must reference IVS.md"
        },
        "has_concrete_phases": {
          "type": "boolean",
          "const": true,
          "description": "Phases must have concrete deliverables"
        }
      }
    }
  }
}
