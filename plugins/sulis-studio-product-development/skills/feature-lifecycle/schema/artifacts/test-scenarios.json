{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-test-scenarios",
  "title": "TEST_SCENARIOS.md Artifact Schema",
  "description": "Required sections and content for Test Scenarios document",
  "type": "object",
  "required": ["sections", "validation", "categories"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "test_scenarios"
    },
    "file_pattern": {
      "type": "string",
      "const": "TEST_SCENARIOS.md"
    },
    "sections": {
      "type": "object",
      "required": ["overview", "scenario_categories", "implementation_mapping"],
      "properties": {
        "overview": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "properties": {
                "scope": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What is covered by these tests" }
                  }
                },
                "derivation_source": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Link to USER_GUIDE.md sections that sourced these tests" }
                  }
                },
                "coverage_summary": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Summary table of test coverage by category" }
                  }
                }
              }
            }
          }
        },
        "scenario_categories": {
          "type": "object",
          "required": ["happy_path", "alternate_path", "security"],
          "properties": {
            "happy_path": {
              "type": "object",
              "required": ["present", "min_scenarios"],
              "properties": {
                "present": { "type": "boolean" },
                "min_scenarios": { "type": "integer", "default": 3 },
                "description": { "type": "string", "const": "Tests for expected successful flows" },
                "id_pattern": { "type": "string", "const": "TS-HP-*" }
              }
            },
            "alternate_path": {
              "type": "object",
              "required": ["present", "min_scenarios"],
              "properties": {
                "present": { "type": "boolean" },
                "min_scenarios": { "type": "integer", "default": 2 },
                "description": { "type": "string", "const": "Tests for valid but non-primary flows" },
                "id_pattern": { "type": "string", "const": "TS-ALT-*" }
              }
            },
            "security": {
              "type": "object",
              "required": ["present", "min_scenarios"],
              "properties": {
                "present": { "type": "boolean" },
                "min_scenarios": { "type": "integer", "default": 3 },
                "description": { "type": "string", "const": "Tests for authentication, authorization, data protection" },
                "id_pattern": { "type": "string", "const": "TS-SEC-*" }
              }
            },
            "referential_integrity": {
              "type": "object",
              "properties": {
                "present": { "type": "boolean" },
                "min_scenarios": { "type": "integer", "default": 2 },
                "description": { "type": "string", "const": "Tests for entity relationships and constraints" },
                "id_pattern": { "type": "string", "const": "TS-RI-*" }
              }
            },
            "journey": {
              "type": "object",
              "properties": {
                "present": { "type": "boolean" },
                "min_scenarios": { "type": "integer", "default": 1 },
                "description": { "type": "string", "const": "End-to-end user journey tests" },
                "id_pattern": { "type": "string", "const": "TS-J-*" }
              }
            },
            "performance": {
              "type": "object",
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "Performance and latency tests" },
                "id_pattern": { "type": "string", "const": "TS-PERF-*" }
              }
            }
          }
        },
        "implementation_mapping": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Mapping from scenario IDs to test file locations" }
          }
        }
      }
    },
    "categories": {
      "type": "object",
      "description": "Test category definitions with ID patterns",
      "properties": {
        "INT-HP": { "type": "string", "const": "Integration Happy Path" },
        "INT-ALT": { "type": "string", "const": "Integration Alternate Path" },
        "INT-SEC": { "type": "string", "const": "Integration Security" },
        "INT-RI": { "type": "string", "const": "Integration Referential Integrity" },
        "INT-J": { "type": "string", "const": "Integration Journey" },
        "TS-HP": { "type": "string", "const": "Test Scenario Happy Path" },
        "TS-ALT": { "type": "string", "const": "Test Scenario Alternate Path" },
        "TS-SEC": { "type": "string", "const": "Test Scenario Security" },
        "TS-RI": { "type": "string", "const": "Test Scenario Referential Integrity" },
        "TS-J": { "type": "string", "const": "Test Scenario Journey" }
      }
    },
    "scenario_format": {
      "type": "object",
      "description": "Required format for each test scenario",
      "required": ["id", "title", "given", "when", "then"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(TS|INT)-(HP|ALT|SEC|RI|J|PERF)-\\d{2}$",
          "description": "Unique scenario identifier"
        },
        "title": {
          "type": "string",
          "description": "Descriptive title"
        },
        "given": {
          "type": "string",
          "description": "Preconditions"
        },
        "when": {
          "type": "string",
          "description": "Action being tested"
        },
        "then": {
          "type": "string",
          "description": "Expected outcome"
        },
        "derived_from": {
          "type": "string",
          "description": "USER_GUIDE.md section this was derived from"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "min_total_scenarios": {
          "type": "integer",
          "default": 10,
          "description": "Minimum total test scenarios"
        },
        "derived_from_user_guide": {
          "type": "boolean",
          "const": true,
          "description": "All scenarios must trace to USER_GUIDE.md"
        },
        "given_when_then_format": {
          "type": "boolean",
          "const": true,
          "description": "All scenarios must use Given/When/Then format"
        },
        "unique_ids": {
          "type": "boolean",
          "const": true,
          "description": "All scenario IDs must be unique"
        }
      }
    }
  }
}
