{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "release-package",
  "title": "Release Package",
  "description": "Output contract for the RELEASE phase - deployed and verified in production",
  "type": "object",
  "required": ["feature_name", "feature_path", "git", "deployment", "production_guardian", "verification"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version identifier"
    },
    "feature_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "feature_path": {
      "type": "string",
      "pattern": "^\\features/[a-z0-9-]+/$"
    },
    "git": {
      "type": "object",
      "required": ["commit_sha", "branch", "pushed"],
      "properties": {
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$",
          "description": "Git commit SHA"
        },
        "branch": {
          "type": "string",
          "description": "Branch name"
        },
        "pushed": {
          "type": "boolean",
          "const": true,
          "description": "Code pushed to remote"
        },
        "pr_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Pull request URL if applicable"
        },
        "pr_merged": {
          "type": ["boolean", "null"],
          "description": "Whether PR was merged"
        },
        "commit_message": {
          "type": "string",
          "description": "Commit message"
        }
      }
    },
    "deployment": {
      "type": "object",
      "required": ["environment", "status", "deployed_at"],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["production", "staging", "development"],
          "description": "Deployment environment"
        },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "pending"],
          "const": "success"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Deployed service URL"
        },
        "deployed_at": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "description": "Deployed version identifier"
        },
        "ci_cd": {
          "type": "object",
          "properties": {
            "pipeline_url": { "type": "string", "format": "uri" },
            "run_id": { "type": "string" },
            "duration_seconds": { "type": "number" }
          }
        }
      }
    },
    "production_guardian": {
      "type": "object",
      "required": ["decision", "report_path"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["APPROVED"],
          "const": "APPROVED",
          "description": "Production Guardian decision - MUST be APPROVED (BLOCKED stops release, CONDITIONAL not allowed)"
        },
        "report_path": {
          "type": "string",
          "pattern": "^\\features/.*/reviews/production-guardian-.*\\.md$",
          "description": "Path to guardian report"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "findings": {
          "type": "object",
          "required": ["blocking"],
          "properties": {
            "blocking": { "type": "integer", "const": 0, "description": "Must be 0 - no blocking issues allowed" },
            "info": { "type": "integer", "description": "Informational notes only" }
          },
          "description": "No warnings allowed - all issues are either blocking (stops release) or informational"
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["health_check", "all_passed", "observability"],
      "properties": {
        "health_check": {
          "type": "string",
          "enum": ["passed", "failed"],
          "const": "passed"
        },
        "smoke_test": {
          "type": "string",
          "enum": ["passed", "failed", "skipped"]
        },
        "all_passed": {
          "type": "boolean",
          "const": true
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "status"],
            "properties": {
              "name": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["passed", "failed", "skipped"]
              },
              "details": { "type": "string" }
            }
          }
        },
        "observability": {
          "type": "object",
          "required": ["logs_accessible", "metrics_flowing", "health_endpoint_verified"],
          "description": "Post-deployment observability verification - REQUIRED",
          "properties": {
            "logs_accessible": {
              "type": "boolean",
              "const": true,
              "description": "Logs are accessible in monitoring system"
            },
            "metrics_flowing": {
              "type": "boolean",
              "const": true,
              "description": "Metrics are being recorded and visible"
            },
            "health_endpoint_verified": {
              "type": "boolean",
              "const": true,
              "description": "Health endpoint returns 200"
            },
            "traces_enabled": {
              "type": "boolean",
              "description": "Distributed tracing enabled (optional)"
            },
            "alerts_configured": {
              "type": "boolean",
              "description": "Alert rules configured (optional but recommended)"
            },
            "verification_commands": {
              "type": "object",
              "description": "Commands used to verify observability",
              "properties": {
                "health_check": { "type": "string" },
                "logs_query": { "type": "string" },
                "metrics_query": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "rollback": {
      "type": "object",
      "properties": {
        "plan_documented": {
          "type": "boolean",
          "description": "Rollback plan documented"
        },
        "previous_version": {
          "type": "string",
          "description": "Version to rollback to if needed"
        },
        "command": {
          "type": "string",
          "description": "Command to execute rollback"
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "elapsed_minutes": { "type": "number", "minimum": 0, "description": "Elapsed wall-clock minutes for release phase" },
        "deploy_attempts": { "type": "integer" },
        "guardian_iterations": { "type": "integer" }
      }
    }
  }
}
