{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "implementation-package",
  "title": "Implementation Package",
  "description": "Output contract for the IMPLEMENTATION phase - tested, verified code ready for release",
  "type": "object",
  "required": ["feature_name", "feature_path", "code_changes", "test_results", "verification_status", "artifacts", "pre_commit"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version identifier"
    },
    "feature_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "feature_path": {
      "type": "string",
      "pattern": "^\\features/[a-z0-9-]+/$"
    },
    "code_changes": {
      "type": "object",
      "required": ["files_added", "files_modified"],
      "properties": {
        "files_added": {
          "type": "array",
          "items": { "type": "string" },
          "description": "New files created"
        },
        "files_modified": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Existing files modified"
        },
        "files_deleted": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files removed"
        },
        "lines_added": {
          "type": "integer",
          "minimum": 0
        },
        "lines_removed": {
          "type": "integer",
          "minimum": 0
        },
        "summary": {
          "type": "string",
          "description": "Brief summary of code changes"
        }
      }
    },
    "test_results": {
      "type": "object",
      "required": ["unit_tests", "integration_tests", "all_passed"],
      "properties": {
        "unit_tests": {
          "type": "object",
          "required": ["passed", "failed", "skipped"],
          "properties": {
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "const": 0 },
            "skipped": { "type": "integer", "minimum": 0 },
            "duration_seconds": { "type": "number" }
          }
        },
        "integration_tests": {
          "type": "object",
          "required": ["passed", "failed", "skipped"],
          "properties": {
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "const": 0 },
            "skipped": { "type": "integer", "minimum": 0 },
            "duration_seconds": { "type": "number" }
          }
        },
        "all_passed": {
          "type": "boolean",
          "const": true,
          "description": "All tests must pass"
        },
        "coverage": {
          "type": "object",
          "properties": {
            "line_coverage": { "type": "number", "minimum": 0, "maximum": 100 },
            "branch_coverage": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    },
    "verification_status": {
      "type": "object",
      "required": ["security", "observability", "reliability", "all_verified"],
      "properties": {
        "security": {
          "$ref": "#/$defs/verification_category"
        },
        "observability": {
          "$ref": "#/$defs/verification_category"
        },
        "reliability": {
          "$ref": "#/$defs/verification_category"
        },
        "all_verified": {
          "type": "boolean",
          "const": true,
          "description": "All IVS requirements verified"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["plan", "tasks", "changelog"],
      "properties": {
        "plan": {
          "type": "object",
          "required": ["path", "valid"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true }
          }
        },
        "tasks": {
          "type": "object",
          "required": ["path", "completed", "total"],
          "properties": {
            "path": { "type": "string" },
            "completed": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 },
            "completion_percentage": {
              "type": "number",
              "const": 100,
              "description": "Must be 100% complete"
            }
          }
        },
        "changelog": {
          "type": "object",
          "required": ["path", "valid", "version"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+",
              "description": "Version being implemented"
            }
          }
        },
        "ivs_updated": {
          "type": "boolean",
          "const": true,
          "description": "IVS.md updated with implementation status"
        }
      }
    },
    "pre_commit": {
      "type": "object",
      "required": ["passed", "timestamp"],
      "properties": {
        "passed": {
          "type": "boolean",
          "const": true,
          "description": "Pre-commit checks must pass"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "checks": {
          "type": "object",
          "properties": {
            "formatting": { "type": "boolean", "const": true },
            "linting": { "type": "boolean", "const": true },
            "type_checking": { "type": "boolean" },
            "unit_tests": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "properties": {
        "reviewed": {
          "type": "boolean",
          "description": "User reviewed implementation"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "comments": {
          "type": "string"
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "elapsed_minutes": { "type": "number", "minimum": 0, "description": "Elapsed wall-clock minutes for implementation phase" },
        "tdd_cycles": { "type": "integer" },
        "refactoring_iterations": { "type": "integer" }
      }
    }
  },
  "$defs": {
    "verification_category": {
      "type": "object",
      "required": ["total", "verified"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 1,
          "description": "Total requirements in this category"
        },
        "verified": {
          "type": "integer",
          "minimum": 0,
          "description": "Requirements verified"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "status"],
            "properties": {
              "id": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["verified", "partial", "not_implemented"]
              },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
