{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "design-package",
  "title": "Design Package",
  "description": "Output contract for the DESIGN phase - complete approved design ready for implementation",
  "type": "object",
  "required": ["feature_name", "feature_path", "artifacts", "approval"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version identifier"
    },
    "feature_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Kebab-case feature identifier"
    },
    "feature_path": {
      "type": "string",
      "pattern": "^\\features/[a-z0-9-]+/$",
      "description": "Path to feature directory"
    },
    "artifacts": {
      "type": "object",
      "required": ["market_evidence", "pr_faq", "user_guide", "test_scenarios", "design", "ivs", "ontology", "traceability", "solution_summary"],
      "properties": {
        "market_evidence": {
          "type": "object",
          "required": ["path", "valid", "validation_status"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "validation_status": {
              "type": "string",
              "enum": ["VALIDATED", "WEAK_APPROVED", "OVERRIDE"],
              "description": "VALIDATED=5+ sources, WEAK_APPROVED=2-4 sources with user approval, OVERRIDE=user chose to proceed without evidence"
            },
            "source_count": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of independent community sources found"
            },
            "has_quantitative_evidence": {
              "type": "boolean",
              "description": "Whether survey/industry report data was found"
            }
          },
          "description": "MARKET_EVIDENCE.md - Must be created FIRST (Step 1.0)"
        },
        "pr_faq": {
          "$ref": "#/$defs/artifact_status",
          "description": "Press Release + FAQ document (references MARKET_EVIDENCE.md)"
        },
        "user_guide": {
          "type": "object",
          "required": ["path", "valid", "sections"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "sections": {
              "type": "object",
              "required": ["getting_started", "how_to", "reference", "faq"],
              "properties": {
                "getting_started": { "type": "boolean" },
                "how_to": { "type": "boolean" },
                "reference": { "type": "boolean" },
                "faq": { "type": "boolean" },
                "troubleshooting": { "type": "boolean" }
              }
            }
          }
        },
        "test_scenarios": {
          "type": "object",
          "required": ["path", "valid", "scenario_count", "categories"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "scenario_count": { "type": "integer", "minimum": 1 },
            "categories": {
              "type": "object",
              "properties": {
                "happy_path": { "type": "integer", "minimum": 0 },
                "alternate_path": { "type": "integer", "minimum": 0 },
                "security": { "type": "integer", "minimum": 0 },
                "referential_integrity": { "type": "integer", "minimum": 0 },
                "journey": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "design": {
          "type": "object",
          "required": ["path", "valid", "sections"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "sections": {
              "type": "object",
              "required": ["overview", "requirements", "architecture", "data_model", "api_contracts", "security", "test_summary"],
              "properties": {
                "overview": { "type": "boolean" },
                "requirements": { "type": "boolean" },
                "architecture": { "type": "boolean" },
                "data_model": { "type": "boolean" },
                "api_contracts": { "type": "boolean" },
                "security": { "type": "boolean" },
                "test_summary": { "type": "boolean" },
                "risks": { "type": "boolean" }
              }
            }
          }
        },
        "ivs": {
          "type": "object",
          "required": ["path", "valid", "verification_requirements"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "verification_requirements": {
              "type": "object",
              "required": ["security", "observability", "reliability"],
              "properties": {
                "security": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^SEC-"
                  },
                  "minItems": 1,
                  "description": "Security verification requirements"
                },
                "observability": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^OBS-"
                  },
                  "minItems": 1,
                  "description": "Observability verification requirements"
                },
                "reliability": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^REL-"
                  },
                  "minItems": 1,
                  "description": "Reliability verification requirements"
                }
              }
            },
            "infrastructure": {
              "type": "object",
              "properties": {
                "gcp_services": { "type": "array", "items": { "type": "string" } },
                "iam_permissions": { "type": "array", "items": { "type": "string" } },
                "terraform_resources": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "ontology": {
          "$ref": "#/$defs/artifact_status",
          "description": "ONTOLOGY.jsonld - LLM-discoverable specification (MANDATORY)"
        },
        "traceability": {
          "$ref": "#/$defs/artifact_status",
          "description": "TRACEABILITY.jsonld linking artifacts"
        },
        "solution_summary": {
          "type": "object",
          "required": ["path", "valid", "sections"],
          "properties": {
            "path": { "type": "string" },
            "valid": { "type": "boolean", "const": true },
            "sections": {
              "type": "object",
              "required": ["executive_brief", "solution_overview", "design_decisions", "coverage_matrix", "risk_summary", "artifact_index", "approval_status"],
              "properties": {
                "executive_brief": { "type": "boolean" },
                "solution_overview": { "type": "boolean" },
                "design_decisions": { "type": "boolean" },
                "coverage_matrix": { "type": "boolean" },
                "risk_summary": { "type": "boolean" },
                "artifact_index": { "type": "boolean" },
                "approval_status": { "type": "boolean" }
              }
            },
            "coverage": {
              "type": "object",
              "properties": {
                "requirements_total": { "type": "integer", "minimum": 0 },
                "requirements_addressed": { "type": "integer", "minimum": 0 },
                "test_scenarios_total": { "type": "integer", "minimum": 0 },
                "placeholders_found": { "type": "integer", "minimum": 0 }
              },
              "description": "Coverage metrics from the summary"
            }
          },
          "description": "SOLUTION_SUMMARY.md - Executive dashboard for stakeholder confidence"
        }
      }
    },
    "registry": {
      "type": "object",
      "required": ["registered", "index_updated"],
      "properties": {
        "registered": {
          "type": "boolean",
          "const": true,
          "description": "Feature directory created in features/"
        },
        "index_updated": {
          "type": "boolean",
          "const": true,
          "description": "features/index.md updated with feature entry"
        }
      }
    },
    "approval": {
      "type": "object",
      "required": ["approved", "approved_at", "approved_by"],
      "properties": {
        "approved": {
          "type": "boolean",
          "const": true,
          "description": "User explicitly approved the design (GATE 1)"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_by": {
          "type": "string"
        },
        "comments": {
          "type": "string",
          "description": "Any comments from approval"
        },
        "validation_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "passed": { "type": "boolean" }
            }
          },
          "description": "Auto-validation checks that passed before user review"
        }
      },
      "description": "GATE 1: User approval of complete design package"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "elapsed_minutes": {
          "type": "number",
          "minimum": 0,
          "description": "Elapsed wall-clock minutes for design phase"
        },
        "iterations": {
          "type": "integer",
          "description": "Number of design iterations before approval"
        }
      }
    }
  },
  "$defs": {
    "artifact_status": {
      "type": "object",
      "required": ["path", "valid"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the artifact file"
        },
        "valid": {
          "type": "boolean",
          "const": true,
          "description": "Artifact passes schema validation"
        },
        "hash": {
          "type": "string",
          "description": "Content hash for change detection"
        }
      }
    }
  }
}
