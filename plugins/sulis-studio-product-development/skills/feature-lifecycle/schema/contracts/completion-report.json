{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "completion-report",
  "title": "Completion Report",
  "description": "Output contract for the COMPLETION phase - final report with user sign-off",
  "type": "object",
  "required": ["feature_name", "feature_path", "status", "summary", "deliverables", "documentation_updates", "sign_off"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version identifier"
    },
    "feature_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "feature_path": {
      "type": "string",
      "pattern": "^\\features/[a-z0-9-]+/$"
    },
    "status": {
      "type": "string",
      "const": "complete",
      "description": "Final status must be complete"
    },
    "summary": {
      "type": "object",
      "required": ["started_at", "completed_at", "elapsed_minutes"],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "When feature work started"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time",
          "description": "When feature was completed"
        },
        "elapsed_minutes": {
          "type": "number",
          "minimum": 0,
          "description": "Elapsed wall-clock minutes from start to completion"
        },
        "ai_metrics": {
          "type": "object",
          "description": "AI-native execution metrics (optional — no instrumentation exists yet)",
          "properties": {
            "token_consumption_approx": {
              "type": "string",
              "description": "Approximate total token consumption"
            },
            "tool_invocations": {
              "type": "integer",
              "description": "Total tool/function invocations"
            },
            "agent_iterations": {
              "type": "integer",
              "description": "Total agent reasoning iterations"
            }
          }
        }
      }
    },
    "deliverables": {
      "type": "object",
      "required": ["artifacts", "code_files"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "path", "type"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["pr_faq", "user_guide", "test_scenarios", "design", "ivs", "traceability", "plan", "tasks", "changelog"]
              }
            }
          },
          "description": "All design and planning artifacts"
        },
        "code_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All code files created or modified"
        },
        "test_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All test files created"
        },
        "documentation": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "updated": { "type": "boolean" }
            }
          },
          "description": "Documentation files updated"
        }
      }
    },
    "documentation_evaluation": {
      "type": "object",
      "required": ["platform_conventions", "docs_folder", "feature_index"],
      "description": "Comprehensive documentation evaluation with trigger-based detection",
      "properties": {
        "platform_conventions": {
          "type": "object",
          "required": ["triggers_evaluated", "triggers_matched", "updated"],
          "properties": {
            "triggers_evaluated": {
              "type": "integer",
              "const": 14,
              "description": "Must evaluate all 14 pattern triggers"
            },
            "triggers_matched": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["trigger", "section", "action"],
                "properties": {
                  "trigger": {
                    "type": "string",
                    "enum": [
                      "New entity ID prefix",
                      "New API endpoint pattern",
                      "New query parameter convention",
                      "New JSON field naming",
                      "New permission pattern",
                      "New authorization pattern",
                      "New identity type",
                      "New interaction level",
                      "New entity structure",
                      "New lifecycle/status values",
                      "New state machine pattern",
                      "New storage abstraction",
                      "New error handling pattern",
                      "New ServiceSpec pattern"
                    ]
                  },
                  "section": {
                    "type": "string",
                    "description": "Section number to update (e.g., '4.2')"
                  },
                  "action": {
                    "type": "string",
                    "enum": ["updated", "not_applicable"],
                    "description": "Whether section was updated or explicitly not applicable"
                  },
                  "update_description": {
                    "type": "string",
                    "description": "What was added/changed"
                  },
                  "justification": {
                    "type": "string",
                    "description": "Required if action is 'not_applicable'"
                  }
                }
              }
            },
            "updated": {
              "type": "boolean",
              "description": "Whether PLATFORM_CONVENTIONS.md was modified"
            },
            "sections_modified": {
              "type": "array",
              "items": { "type": "string" },
              "description": "List of section numbers modified"
            },
            "changelog_entry_added": {
              "type": "boolean",
              "description": "Entry added to PLATFORM_CONVENTIONS.md changelog"
            }
          }
        },
        "docs_folder": {
          "type": "object",
          "required": ["triggers_evaluated", "triggers_matched", "updated"],
          "properties": {
            "triggers_evaluated": {
              "type": "integer",
              "const": 6,
              "description": "Must evaluate all 6 /docs triggers"
            },
            "triggers_matched": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["trigger", "action"],
                "properties": {
                  "trigger": {
                    "type": "string",
                    "enum": [
                      "User-facing API endpoints",
                      "New configuration options",
                      "New concepts/terminology",
                      "New workflows/processes",
                      "Security-relevant changes",
                      "Breaking changes"
                    ]
                  },
                  "action": {
                    "type": "string",
                    "enum": ["created", "updated", "not_applicable"]
                  },
                  "file_path": {
                    "type": "string",
                    "description": "Path to documentation file"
                  },
                  "justification": {
                    "type": "string",
                    "description": "Required if action is 'not_applicable'"
                  }
                }
              }
            },
            "updated": {
              "type": "boolean",
              "description": "Whether /docs folder was modified"
            },
            "files_created": {
              "type": "array",
              "items": { "type": "string" }
            },
            "files_modified": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "readme": {
          "type": "object",
          "required": ["evaluated", "needs_update"],
          "properties": {
            "evaluated": {
              "type": "boolean",
              "const": true
            },
            "needs_update": {
              "type": "boolean"
            },
            "updated": {
              "type": "boolean"
            },
            "justification": {
              "type": "string",
              "description": "Why README does/doesn't need update"
            }
          }
        },
        "feature_index": {
          "type": "object",
          "required": ["updated", "status_set_to_complete"],
          "properties": {
            "updated": {
              "type": "boolean",
              "const": true
            },
            "status_set_to_complete": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "adrs_created": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "adr_number": { "type": "string" },
              "title": { "type": "string" },
              "path": { "type": "string" }
            }
          },
          "description": "ADRs created for architectural decisions"
        }
      }
    },
    "deferrals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "phase", "follow_up"],
        "properties": {
          "item": { "type": "string" },
          "phase": { "type": "string" },
          "reason": { "type": "string" },
          "follow_up": { "type": "string" },
          "ticket_created": { "type": "boolean" }
        }
      },
      "description": "Items deferred with user approval"
    },
    "lessons_learned": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["process", "technical", "tooling", "documentation"]
          },
          "observation": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      },
      "description": "Lessons learned during development"
    },
    "sign_off": {
      "type": "object",
      "required": ["signed", "signed_at", "signed_by"],
      "properties": {
        "signed": {
          "type": "boolean",
          "const": true,
          "description": "User explicitly signed off"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signed_by": {
          "type": "string"
        },
        "comments": {
          "type": "string",
          "description": "Any final comments from user"
        }
      }
    },
    "lifecycle_state": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^\\features/.*/LIFECYCLE_STATE\\.json$"
        },
        "finalized": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
