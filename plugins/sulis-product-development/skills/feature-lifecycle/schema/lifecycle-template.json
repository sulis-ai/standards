{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feature-lifecycle-template",
  "title": "Feature Lifecycle Template",
  "description": "Master template defining the feature development lifecycle phases, contracts, and gates",
  "type": "object",
  "required": ["version", "phases", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Template version for compatibility tracking"
    },
    "phases": {
      "type": "object",
      "required": ["design", "implementation", "release", "completion"],
      "properties": {
        "design": {
          "$ref": "#/$defs/phase",
          "properties": {
            "name": { "const": "design" },
            "input_contract": { "const": "contracts/feature-request.json" },
            "output_contract": { "const": "contracts/design-package.json" },
            "gate": { "const": "gates/design-approval.json" },
            "next_phase": { "const": "implementation" }
          }
        },
        "implementation": {
          "$ref": "#/$defs/phase",
          "properties": {
            "name": { "const": "implementation" },
            "input_contract": { "const": "contracts/design-package.json" },
            "output_contract": { "const": "contracts/implementation-package.json" },
            "gate": { "const": "gates/implementation-complete.json" },
            "next_phase": { "const": "release" }
          }
        },
        "release": {
          "$ref": "#/$defs/phase",
          "properties": {
            "name": { "const": "release" },
            "input_contract": { "const": "contracts/implementation-package.json" },
            "output_contract": { "const": "contracts/release-package.json" },
            "gate": { "const": "gates/release-complete.json" },
            "next_phase": { "const": "completion" }
          }
        },
        "completion": {
          "$ref": "#/$defs/phase",
          "properties": {
            "name": { "const": "completion" },
            "input_contract": { "const": "contracts/release-package.json" },
            "output_contract": { "const": "contracts/completion-report.json" },
            "gate": { "const": "gates/user-signoff.json" },
            "next_phase": { "type": "null" }
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "required": ["deferral_policy", "transition_policy", "failure_policy"],
      "properties": {
        "deferral_policy": {
          "type": "object",
          "required": ["requires_approval", "must_document"],
          "properties": {
            "requires_approval": {
              "type": "boolean",
              "const": true,
              "description": "Deferrals MUST have explicit user approval"
            },
            "must_document": {
              "type": "boolean",
              "const": true,
              "description": "Deferrals MUST be documented with reason and follow-up"
            },
            "required_fields": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["phase", "item", "reason", "approved_by", "approved_at", "follow_up"]
            }
          }
        },
        "transition_policy": {
          "type": "object",
          "required": ["gate_must_pass", "output_must_validate"],
          "properties": {
            "gate_must_pass": {
              "type": "boolean",
              "const": true,
              "description": "Gate must pass before transitioning to next phase"
            },
            "output_must_validate": {
              "type": "boolean",
              "const": true,
              "description": "Output must validate against schema before transition"
            },
            "state_must_persist": {
              "type": "boolean",
              "const": true,
              "description": "LIFECYCLE_STATE.json must be updated at every transition"
            }
          }
        },
        "failure_policy": {
          "type": "object",
          "required": ["on_gate_failure", "on_validation_failure"],
          "properties": {
            "on_gate_failure": {
              "type": "string",
              "enum": ["block", "retry", "escalate"],
              "default": "block",
              "description": "Action when gate fails"
            },
            "on_validation_failure": {
              "type": "string",
              "enum": ["block", "retry"],
              "default": "block",
              "description": "Action when output validation fails"
            },
            "max_retries": {
              "type": "integer",
              "default": 3,
              "description": "Maximum retries before escalation"
            }
          }
        }
      }
    },
    "skills_integration": {
      "type": "object",
      "description": "Skills invoked by each phase",
      "properties": {
        "design": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["solution-design", "test-scenarios"]
        },
        "implementation": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["backend-development", "pre-commit-checks"]
        },
        "release": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["production-guardian"]
        },
        "completion": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "required": ["name", "description", "input_contract", "output_contract", "gate", "internal_tasks"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["design", "implementation", "release", "completion"]
        },
        "description": {
          "type": "string"
        },
        "input_contract": {
          "type": "string",
          "pattern": "^contracts/.*\\.json$",
          "description": "Path to input JSON schema"
        },
        "output_contract": {
          "type": "string",
          "pattern": "^contracts/.*\\.json$",
          "description": "Path to output JSON schema"
        },
        "gate": {
          "type": "string",
          "pattern": "^gates/.*\\.json$",
          "description": "Path to gate criteria schema"
        },
        "next_phase": {
          "type": ["string", "null"],
          "enum": ["design", "implementation", "release", "completion", null],
          "description": "Next phase to transition to (null for final phase)"
        },
        "internal_tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "required": { "type": "boolean", "default": true }
            }
          },
          "description": "Internal tasks executed within this phase (atomic, opaque to external)"
        }
      }
    }
  },
  "default": {
    "version": "1.0.0",
    "phases": {
      "design": {
        "name": "design",
        "description": "Transform feature request into approved design artifacts",
        "input_contract": "contracts/feature-request.json",
        "output_contract": "contracts/design-package.json",
        "gate": "gates/design-approval.json",
        "next_phase": "implementation",
        "internal_tasks": [
          { "name": "working_backwards", "description": "Create PR_FAQ.md and USER_GUIDE.md" },
          { "name": "test_scenarios", "description": "Derive TEST_SCENARIOS.md from User Guide" },
          { "name": "technical_design", "description": "Create DESIGN.md with architecture" },
          { "name": "ivs_creation", "description": "Create IVS.md with verification requirements" },
          { "name": "feature_registration", "description": "Register in features/ and create TRACEABILITY.jsonld" }
        ]
      },
      "implementation": {
        "name": "implementation",
        "description": "Execute design with TDD to create production-ready code",
        "input_contract": "contracts/design-package.json",
        "output_contract": "contracts/implementation-package.json",
        "gate": "gates/implementation-complete.json",
        "next_phase": "release",
        "internal_tasks": [
          { "name": "planning", "description": "Create PLAN.md and TASKS.md" },
          { "name": "outer_loop_tests", "description": "Write integration tests (all FAILING initially)" },
          { "name": "inner_loop_tdd", "description": "Unit TDD: RED → GREEN → REFACTOR" },
          { "name": "ivs_verification", "description": "Verify all SEC-*/OBS-*/REL-* requirements" },
          { "name": "pre_commit", "description": "Run pre-commit checks" }
        ]
      },
      "release": {
        "name": "release",
        "description": "Deploy to production and verify deployment success",
        "input_contract": "contracts/implementation-package.json",
        "output_contract": "contracts/release-package.json",
        "gate": "gates/release-complete.json",
        "next_phase": "completion",
        "internal_tasks": [
          { "name": "commit_push", "description": "Commit and push to remote" },
          { "name": "deployment", "description": "Monitor CI/CD and verify deployment" },
          { "name": "production_guardian", "description": "Run Production Guardian review" },
          { "name": "post_deployment", "description": "Verify production functionality" }
        ]
      },
      "completion": {
        "name": "completion",
        "description": "Finalize documentation and obtain user sign-off",
        "input_contract": "contracts/release-package.json",
        "output_contract": "contracts/completion-report.json",
        "gate": "gates/user-signoff.json",
        "next_phase": null,
        "internal_tasks": [
          { "name": "documentation_updates", "description": "Update PLATFORM_CONVENTIONS.md and /docs" },
          { "name": "registry_update", "description": "Update features/index.md status" },
          { "name": "state_finalization", "description": "Finalize LIFECYCLE_STATE.json" },
          { "name": "user_signoff", "description": "Present summary and request sign-off" }
        ]
      }
    },
    "rules": {
      "deferral_policy": {
        "requires_approval": true,
        "must_document": true,
        "required_fields": ["phase", "item", "reason", "approved_by", "approved_at", "follow_up"]
      },
      "transition_policy": {
        "gate_must_pass": true,
        "output_must_validate": true,
        "state_must_persist": true
      },
      "failure_policy": {
        "on_gate_failure": "block",
        "on_validation_failure": "block",
        "max_retries": 3
      }
    },
    "skills_integration": {
      "design": ["solution-design", "test-scenarios"],
      "implementation": ["backend-development", "pre-commit-checks"],
      "release": ["production-guardian"],
      "completion": []
    }
  }
}
