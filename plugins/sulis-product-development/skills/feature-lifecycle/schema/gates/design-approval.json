{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "design-approval-gate",
  "title": "Design Approval Gate (GATE 1)",
  "description": "Gate criteria for transitioning from DESIGN to IMPLEMENTATION phase - requires user approval of complete design package",
  "type": "object",
  "required": ["automated_checks", "user_approval", "passed"],
  "properties": {
    "gate_id": {
      "type": "string",
      "const": "gate-1-design-approval"
    },
    "phase": {
      "type": "string",
      "const": "design"
    },
    "automated_checks": {
      "type": "object",
      "required": [
        "artifacts_exist",
        "pr_faq_valid",
        "user_guide_valid",
        "test_scenarios_valid",
        "design_valid",
        "ivs_valid",
        "ontology_valid",
        "traceability_valid",
        "feature_registered"
      ],
      "properties": {
        "artifacts_exist": {
          "type": "object",
          "required": ["passed", "details"],
          "properties": {
            "passed": { "type": "boolean" },
            "details": {
              "type": "object",
              "properties": {
                "pr_faq_exists": { "type": "boolean" },
                "user_guide_exists": { "type": "boolean" },
                "test_scenarios_exists": { "type": "boolean" },
                "design_exists": { "type": "boolean" },
                "ivs_exists": { "type": "boolean" },
                "ontology_exists": { "type": "boolean" },
                "traceability_exists": { "type": "boolean" }
              }
            }
          },
          "description": "All required artifacts exist"
        },
        "pr_faq_valid": {
          "$ref": "#/$defs/artifact_check",
          "description": "PR_FAQ.md has required sections"
        },
        "user_guide_valid": {
          "type": "object",
          "required": ["passed", "sections"],
          "properties": {
            "passed": { "type": "boolean" },
            "sections": {
              "type": "object",
              "required": ["getting_started", "how_to", "reference", "faq"],
              "properties": {
                "getting_started": { "type": "boolean" },
                "how_to": { "type": "boolean" },
                "reference": { "type": "boolean" },
                "faq": { "type": "boolean" },
                "troubleshooting": { "type": "boolean" }
              }
            }
          },
          "description": "USER_GUIDE.md has required sections"
        },
        "test_scenarios_valid": {
          "type": "object",
          "required": ["passed", "scenario_count", "derived_from_user_guide"],
          "properties": {
            "passed": { "type": "boolean" },
            "scenario_count": { "type": "integer", "minimum": 1 },
            "derived_from_user_guide": { "type": "boolean" },
            "categories": {
              "type": "object",
              "properties": {
                "happy_path": { "type": "integer" },
                "alternate_path": { "type": "integer" },
                "security": { "type": "integer" },
                "referential_integrity": { "type": "integer" },
                "journey": { "type": "integer" }
              }
            }
          },
          "description": "TEST_SCENARIOS.md derived from User Guide"
        },
        "design_valid": {
          "type": "object",
          "required": ["passed", "sections"],
          "properties": {
            "passed": { "type": "boolean" },
            "sections": {
              "type": "object",
              "required": ["overview", "requirements", "architecture", "data_model", "api_contracts", "security", "test_summary"],
              "additionalProperties": { "type": "boolean" }
            }
          },
          "description": "DESIGN.md has required architecture sections"
        },
        "ivs_valid": {
          "type": "object",
          "required": ["passed", "has_security", "has_observability", "has_reliability"],
          "properties": {
            "passed": { "type": "boolean" },
            "has_security": { "type": "boolean" },
            "has_observability": { "type": "boolean" },
            "has_reliability": { "type": "boolean" },
            "requirement_counts": {
              "type": "object",
              "properties": {
                "security": { "type": "integer", "minimum": 1 },
                "observability": { "type": "integer", "minimum": 1 },
                "reliability": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "description": "IVS.md has SEC-*/OBS-*/REL-* requirements - ALL BLOCKING"
        },
        "ontology_valid": {
          "type": "object",
          "required": ["passed", "has_entities", "has_operations", "has_errors"],
          "properties": {
            "passed": { "type": "boolean" },
            "has_entities": { "type": "boolean" },
            "has_operations": { "type": "boolean" },
            "has_errors": { "type": "boolean" },
            "has_workflows": { "type": "boolean" },
            "has_guides": { "type": "boolean" }
          },
          "description": "ONTOLOGY.jsonld is valid and has required sections (MANDATORY)"
        },
        "traceability_valid": {
          "$ref": "#/$defs/artifact_check",
          "description": "TRACEABILITY.jsonld is valid JSON-LD"
        },
        "feature_registered": {
          "type": "object",
          "required": ["passed", "directory_created", "index_updated"],
          "properties": {
            "passed": { "type": "boolean" },
            "directory_created": { "type": "boolean" },
            "index_updated": { "type": "boolean" },
            "feature_path": { "type": "string" }
          },
          "description": "Feature registered in features/"
        }
      }
    },
    "user_approval": {
      "type": "object",
      "required": ["required", "approved"],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true,
          "description": "User approval is required for this gate"
        },
        "approved": {
          "type": "boolean",
          "description": "User explicitly approved the complete design package"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_by": {
          "type": "string"
        },
        "comments": {
          "type": "string",
          "description": "Any comments from the user during approval"
        }
      },
      "description": "GATE 1: User reviews and approves complete design package (PR_FAQ, USER_GUIDE, DESIGN, IVS, ONTOLOGY, etc.) together"
    },
    "passed": {
      "type": "boolean",
      "description": "Overall gate result - requires both auto-validation AND user approval"
    },
    "passed_at": {
      "type": "string",
      "format": "date-time"
    },
    "failure_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reasons if gate failed"
    }
  },
  "$defs": {
    "artifact_check": {
      "type": "object",
      "required": ["passed"],
      "properties": {
        "passed": { "type": "boolean" },
        "path": { "type": "string" },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
