{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "implementation-complete-gate",
  "title": "Implementation Complete Gate",
  "description": "Gate criteria for transitioning from IMPLEMENTATION to RELEASE phase",
  "type": "object",
  "required": ["automated_checks", "user_review", "passed"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version identifier"
    },
    "gate_id": {
      "type": "string",
      "const": "gate-2-implementation-complete"
    },
    "phase": {
      "type": "string",
      "const": "implementation"
    },
    "automated_checks": {
      "type": "object",
      "required": [
        "unit_tests_pass",
        "integration_tests_pass",
        "pre_commit_pass",
        "ivs_requirements_verified",
        "tasks_complete",
        "changelog_updated"
      ],
      "properties": {
        "unit_tests_pass": {
          "type": "object",
          "required": ["passed", "total", "passed_count", "failed_count"],
          "properties": {
            "passed": { "type": "boolean" },
            "total": { "type": "integer", "minimum": 0 },
            "passed_count": { "type": "integer", "minimum": 0 },
            "failed_count": { "type": "integer", "const": 0 },
            "skipped_count": { "type": "integer" },
            "duration_seconds": { "type": "number" }
          },
          "description": "All unit tests pass (zero failures)"
        },
        "integration_tests_pass": {
          "type": "object",
          "required": ["passed", "total", "passed_count", "failed_count"],
          "properties": {
            "passed": { "type": "boolean" },
            "total": { "type": "integer", "minimum": 0 },
            "passed_count": { "type": "integer", "minimum": 0 },
            "failed_count": { "type": "integer", "const": 0 },
            "skipped_count": { "type": "integer" },
            "duration_seconds": { "type": "number" }
          },
          "description": "All integration tests pass (zero failures)"
        },
        "pre_commit_pass": {
          "type": "object",
          "required": ["passed", "checks"],
          "properties": {
            "passed": { "type": "boolean" },
            "checks": {
              "type": "object",
              "required": ["formatting", "linting", "tests"],
              "properties": {
                "formatting": {
                  "type": "object",
                  "required": ["passed"],
                  "properties": {
                    "passed": { "type": "boolean" },
                    "tool": { "type": "string", "default": "ruff format" }
                  }
                },
                "linting": {
                  "type": "object",
                  "required": ["passed"],
                  "properties": {
                    "passed": { "type": "boolean" },
                    "tool": { "type": "string", "default": "ruff check" },
                    "errors": { "type": "integer" },
                    "warnings": { "type": "integer" }
                  }
                },
                "tests": {
                  "type": "object",
                  "required": ["passed"],
                  "properties": {
                    "passed": { "type": "boolean" }
                  }
                },
                "type_checking": {
                  "type": "object",
                  "properties": {
                    "passed": { "type": "boolean" },
                    "tool": { "type": "string", "default": "mypy" }
                  }
                }
              }
            },
            "command": { "type": "string", "default": "uv run nox -s pre-commit" },
            "timestamp": { "type": "string", "format": "date-time" }
          },
          "description": "Pre-commit checks pass"
        },
        "ivs_requirements_verified": {
          "type": "object",
          "required": ["passed", "security", "observability", "reliability"],
          "properties": {
            "passed": { "type": "boolean" },
            "security": {
              "type": "object",
              "required": ["total", "verified", "all_verified"],
              "properties": {
                "total": { "type": "integer", "minimum": 1 },
                "verified": { "type": "integer" },
                "all_verified": { "type": "boolean" },
                "requirements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "verified"],
                    "properties": {
                      "id": { "type": "string", "pattern": "^SEC-" },
                      "verified": { "type": "boolean" },
                      "evidence": { "type": "string" }
                    }
                  }
                }
              }
            },
            "observability": {
              "type": "object",
              "required": ["total", "verified", "all_verified"],
              "properties": {
                "total": { "type": "integer", "minimum": 1 },
                "verified": { "type": "integer" },
                "all_verified": { "type": "boolean" },
                "requirements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "verified"],
                    "properties": {
                      "id": { "type": "string", "pattern": "^OBS-" },
                      "verified": { "type": "boolean" },
                      "evidence": { "type": "string" }
                    }
                  }
                }
              }
            },
            "reliability": {
              "type": "object",
              "required": ["total", "verified", "all_verified"],
              "properties": {
                "total": { "type": "integer", "minimum": 1 },
                "verified": { "type": "integer" },
                "all_verified": { "type": "boolean" },
                "requirements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "verified"],
                    "properties": {
                      "id": { "type": "string", "pattern": "^REL-" },
                      "verified": { "type": "boolean" },
                      "evidence": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "description": "All IVS verification requirements verified"
        },
        "tasks_complete": {
          "type": "object",
          "required": ["passed", "completed", "total", "percentage"],
          "properties": {
            "passed": { "type": "boolean" },
            "completed": { "type": "integer" },
            "total": { "type": "integer" },
            "percentage": { "type": "number", "const": 100 }
          },
          "description": "TASKS.md 100% complete"
        },
        "changelog_updated": {
          "type": "object",
          "required": ["passed", "version_documented"],
          "properties": {
            "passed": { "type": "boolean" },
            "version_documented": { "type": "boolean" },
            "version": { "type": "string" }
          },
          "description": "CHANGELOG.md updated with changes"
        }
      }
    },
    "user_review": {
      "type": "object",
      "required": ["required", "reviewed"],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "reviewed": {
          "type": "boolean",
          "description": "User reviewed implementation"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "reviewed_by": {
          "type": "string"
        },
        "approved": {
          "type": "boolean",
          "description": "User approves implementation"
        },
        "feedback": {
          "type": "string",
          "description": "Any feedback from review"
        }
      }
    },
    "passed": {
      "type": "boolean",
      "description": "Overall gate result"
    },
    "passed_at": {
      "type": "string",
      "format": "date-time"
    },
    "failure_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reasons if gate failed"
    }
  }
}
