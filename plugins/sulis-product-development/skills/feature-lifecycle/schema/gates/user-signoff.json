{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user-signoff-gate",
  "title": "User Sign-off Gate",
  "description": "Final gate - user explicitly signs off on completed feature",
  "type": "object",
  "required": ["automated_checks", "user_signoff", "passed"],
  "properties": {
    "gate_id": {
      "type": "string",
      "const": "gate-4-user-signoff"
    },
    "phase": {
      "type": "string",
      "const": "completion"
    },
    "automated_checks": {
      "type": "object",
      "required": [
        "documentation_verification",
        "feature_registry_updated",
        "lifecycle_state_finalized"
      ],
      "properties": {
        "documentation_verification": {
          "type": "object",
          "required": ["passed", "platform_conventions_check", "docs_folder_check"],
          "description": "MANDATORY: All triggers must be evaluated - no shortcuts",
          "properties": {
            "passed": {
              "type": "boolean",
              "description": "True only if ALL triggers evaluated and documented"
            },
            "platform_conventions_check": {
              "type": "object",
              "required": ["triggers_evaluated_count", "all_triggers_documented", "verification_details"],
              "description": "Must evaluate ALL 14 PLATFORM_CONVENTIONS.md triggers",
              "properties": {
                "triggers_evaluated_count": {
                  "type": "integer",
                  "const": 14,
                  "description": "MUST be exactly 14 - all triggers evaluated"
                },
                "all_triggers_documented": {
                  "type": "boolean",
                  "const": true,
                  "description": "Each trigger has action + justification if not_applicable"
                },
                "file_updated": { "type": "boolean" },
                "sections_modified": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Section numbers that were updated (e.g., ['1.8', '4.2'])"
                },
                "changelog_entry_added": {
                  "type": "boolean",
                  "description": "Entry added to PLATFORM_CONVENTIONS.md changelog section"
                },
                "verification_details": {
                  "type": "array",
                  "minItems": 14,
                  "maxItems": 14,
                  "items": {
                    "type": "object",
                    "required": ["trigger", "action"],
                    "properties": {
                      "trigger": {
                        "type": "string",
                        "enum": [
                          "New entity ID prefix",
                          "New API endpoint pattern",
                          "New query parameter convention",
                          "New JSON field naming",
                          "New permission pattern",
                          "New authorization pattern",
                          "New identity type",
                          "New interaction level",
                          "New entity structure",
                          "New lifecycle/status values",
                          "New state machine pattern",
                          "New storage abstraction",
                          "New error handling pattern",
                          "New ServiceSpec pattern"
                        ]
                      },
                      "action": {
                        "type": "string",
                        "enum": ["updated", "not_applicable"]
                      },
                      "section": {
                        "type": "string",
                        "description": "Section number if updated (e.g., '4.2')"
                      },
                      "justification": {
                        "type": "string",
                        "description": "REQUIRED if action is 'not_applicable' - why doesn't this trigger apply?"
                      }
                    }
                  },
                  "description": "Each of the 14 triggers with explicit evaluation"
                }
              }
            },
            "docs_folder_check": {
              "type": "object",
              "required": ["triggers_evaluated_count", "all_triggers_documented", "verification_details"],
              "description": "Must evaluate ALL 6 /docs folder triggers",
              "properties": {
                "triggers_evaluated_count": {
                  "type": "integer",
                  "const": 6,
                  "description": "MUST be exactly 6 - all triggers evaluated"
                },
                "all_triggers_documented": {
                  "type": "boolean",
                  "const": true,
                  "description": "Each trigger has action + justification if not_applicable"
                },
                "folder_updated": { "type": "boolean" },
                "files_created": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "files_modified": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "verification_details": {
                  "type": "array",
                  "minItems": 6,
                  "maxItems": 6,
                  "items": {
                    "type": "object",
                    "required": ["trigger", "action"],
                    "properties": {
                      "trigger": {
                        "type": "string",
                        "enum": [
                          "User-facing API endpoints",
                          "New configuration options",
                          "New concepts/terminology",
                          "New workflows/processes",
                          "Security-relevant changes",
                          "Breaking changes"
                        ]
                      },
                      "action": {
                        "type": "string",
                        "enum": ["created", "updated", "not_applicable"]
                      },
                      "file_path": {
                        "type": "string",
                        "description": "Path if created or updated"
                      },
                      "justification": {
                        "type": "string",
                        "description": "REQUIRED if action is 'not_applicable' - why doesn't this trigger apply?"
                      }
                    }
                  },
                  "description": "Each of the 6 triggers with explicit evaluation"
                }
              }
            },
            "readme_check": {
              "type": "object",
              "properties": {
                "evaluated": {
                  "type": "boolean",
                  "const": true
                },
                "needs_update": { "type": "boolean" },
                "updated": { "type": "boolean" },
                "justification": {
                  "type": "string",
                  "description": "Why README does/doesn't need update"
                }
              }
            },
            "failure_reasons": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Why documentation verification failed (if passed=false)"
            }
          }
        },
        "feature_registry_updated": {
          "type": "object",
          "required": ["passed", "status_set_to_complete"],
          "properties": {
            "passed": { "type": "boolean" },
            "status_set_to_complete": { "type": "boolean" },
            "index_path": { "type": "string", "default": "features/index.md" },
            "feature_entry_found": { "type": "boolean" }
          },
          "description": "features/index.md status updated to complete"
        },
        "lifecycle_state_finalized": {
          "type": "object",
          "required": ["passed", "all_phases_complete", "current_phase_is_complete"],
          "properties": {
            "passed": { "type": "boolean" },
            "path": { "type": "string" },
            "all_phases_complete": { "type": "boolean" },
            "current_phase_is_complete": { "type": "boolean" },
            "completed_at_set": { "type": "boolean" }
          },
          "description": "LIFECYCLE_STATE.json finalized"
        },
        "planning_archived": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "files_archived": { "type": "array", "items": { "type": "string" } },
            "not_applicable": { "type": "boolean" }
          },
          "description": "Any .sulis/planning/active/ files archived"
        }
      }
    },
    "user_signoff": {
      "type": "object",
      "required": ["required", "signed"],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true,
          "description": "User sign-off is mandatory"
        },
        "signed": {
          "type": "boolean",
          "description": "User explicitly signed off"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signed_by": {
          "type": "string"
        },
        "confirmation_message": {
          "type": "string",
          "description": "User's confirmation message"
        },
        "accepts_deliverables": {
          "type": "boolean",
          "description": "User accepts all deliverables"
        },
        "acknowledges_deferrals": {
          "type": "boolean",
          "description": "User acknowledges any deferred items"
        },
        "final_comments": {
          "type": "string",
          "description": "Any final comments from user"
        }
      }
    },
    "summary_presented": {
      "type": "object",
      "properties": {
        "presented": { "type": "boolean" },
        "presented_at": { "type": "string", "format": "date-time" },
        "summary_includes": {
          "type": "object",
          "properties": {
            "duration": { "type": "boolean" },
            "deliverables": { "type": "boolean" },
            "deployment_status": { "type": "boolean" },
            "deferrals": { "type": "boolean" }
          }
        }
      },
      "description": "Completion summary presented to user"
    },
    "passed": {
      "type": "boolean",
      "description": "Overall gate result"
    },
    "passed_at": {
      "type": "string",
      "format": "date-time"
    },
    "failure_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reasons if gate failed"
    }
  }
}
