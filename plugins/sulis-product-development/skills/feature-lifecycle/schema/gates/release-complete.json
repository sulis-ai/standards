{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "release-complete-gate",
  "title": "Release Complete Gate",
  "description": "Gate criteria for transitioning from RELEASE to COMPLETION phase",
  "type": "object",
  "required": ["automated_checks", "passed"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version identifier"
    },
    "gate_id": {
      "type": "string",
      "const": "gate-3-release-complete"
    },
    "phase": {
      "type": "string",
      "const": "release"
    },
    "automated_checks": {
      "type": "object",
      "required": [
        "code_pushed",
        "ci_cd_succeeded",
        "deployment_healthy",
        "production_guardian_approved",
        "post_deployment_verified"
      ],
      "properties": {
        "code_pushed": {
          "type": "object",
          "required": ["passed", "commit_sha", "branch"],
          "properties": {
            "passed": { "type": "boolean" },
            "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
            "branch": { "type": "string" },
            "remote": { "type": "string", "default": "origin" },
            "pushed_at": { "type": "string", "format": "date-time" }
          },
          "description": "Code pushed to remote repository"
        },
        "ci_cd_succeeded": {
          "type": "object",
          "required": ["passed", "pipeline_status"],
          "properties": {
            "passed": { "type": "boolean" },
            "pipeline_status": {
              "type": "string",
              "enum": ["success", "failed", "pending", "running"]
            },
            "pipeline_url": { "type": "string", "format": "uri" },
            "run_id": { "type": "string" },
            "duration_seconds": { "type": "number" },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "status": { "type": "string" },
                  "duration_seconds": { "type": "number" }
                }
              }
            }
          },
          "description": "CI/CD pipeline succeeded"
        },
        "deployment_healthy": {
          "type": "object",
          "required": ["passed", "status"],
          "properties": {
            "passed": { "type": "boolean" },
            "status": {
              "type": "string",
              "enum": ["healthy", "unhealthy", "degraded"]
            },
            "environment": {
              "type": "string",
              "enum": ["production", "staging", "development"]
            },
            "url": { "type": "string", "format": "uri" },
            "health_check": {
              "type": "object",
              "properties": {
                "endpoint": { "type": "string" },
                "status_code": { "type": "integer" },
                "response_time_ms": { "type": "number" }
              }
            },
            "replicas": {
              "type": "object",
              "properties": {
                "desired": { "type": "integer" },
                "ready": { "type": "integer" },
                "available": { "type": "integer" }
              }
            }
          },
          "description": "Deployment is healthy"
        },
        "production_guardian_approved": {
          "type": "object",
          "required": ["passed", "decision"],
          "properties": {
            "passed": { "type": "boolean" },
            "decision": {
              "type": "string",
              "enum": ["APPROVED", "CONDITIONAL", "BLOCKED"]
            },
            "report_path": { "type": "string" },
            "reviewed_at": { "type": "string", "format": "date-time" },
            "findings": {
              "type": "object",
              "properties": {
                "blocking": { "type": "integer" },
                "warnings": { "type": "integer" },
                "info": { "type": "integer" }
              }
            },
            "conditions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "condition": { "type": "string" },
                  "addressed": { "type": "boolean" },
                  "how_addressed": { "type": "string" }
                }
              },
              "description": "Conditions if CONDITIONAL decision"
            },
            "blocking_issues_resolved": {
              "type": "boolean",
              "description": "True if all blocking issues were resolved"
            }
          },
          "description": "Production Guardian approved (not BLOCKED)"
        },
        "post_deployment_verified": {
          "type": "object",
          "required": ["passed", "checks"],
          "properties": {
            "passed": { "type": "boolean" },
            "checks": {
              "type": "object",
              "required": ["health_check"],
              "properties": {
                "health_check": {
                  "type": "object",
                  "required": ["passed"],
                  "properties": {
                    "passed": { "type": "boolean" },
                    "endpoint": { "type": "string" },
                    "response_time_ms": { "type": "number" }
                  }
                },
                "smoke_test": {
                  "type": "object",
                  "properties": {
                    "passed": { "type": "boolean" },
                    "tests_run": { "type": "integer" },
                    "tests_passed": { "type": "integer" }
                  }
                },
                "logs_accessible": {
                  "type": "object",
                  "properties": {
                    "passed": { "type": "boolean" },
                    "log_source": { "type": "string" }
                  }
                },
                "metrics_flowing": {
                  "type": "object",
                  "properties": {
                    "passed": { "type": "boolean" },
                    "metrics_source": { "type": "string" }
                  }
                }
              }
            }
          },
          "description": "Post-deployment verification passed"
        }
      }
    },
    "passed": {
      "type": "boolean",
      "description": "Overall gate result"
    },
    "passed_at": {
      "type": "string",
      "format": "date-time"
    },
    "failure_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reasons if gate failed"
    },
    "retry_count": {
      "type": "integer",
      "default": 0,
      "description": "Number of retry attempts"
    }
  }
}
