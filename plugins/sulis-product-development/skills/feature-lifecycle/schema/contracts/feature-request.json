{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feature-request",
  "title": "Feature Request",
  "description": "Input contract for the DESIGN phase - captures initial feature request",
  "type": "object",
  "required": ["feature_name", "description", "problem_statement", "requested_by"],
  "properties": {
    "feature_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 3,
      "maxLength": 50,
      "description": "Kebab-case feature identifier (e.g., 'storage-service', 'user-auth')"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500,
      "description": "Brief description of what the feature does"
    },
    "problem_statement": {
      "type": "string",
      "minLength": 50,
      "description": "Detailed explanation of the problem being solved"
    },
    "requested_by": {
      "type": "string",
      "enum": ["user", "system", "internal"],
      "description": "Who requested this feature"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "default": "medium",
      "description": "Priority level for the feature"
    },
    "target_users": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Who will use this feature"
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "How we'll know the feature is successful"
    },
    "constraints": {
      "type": "object",
      "properties": {
        "timeline": {
          "type": "string",
          "description": "Any timeline constraints"
        },
        "technical": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Technical constraints to consider"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dependencies on other features or systems"
        }
      }
    },
    "related_features": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "description": "Related existing features to consider"
    },
    "initial_context": {
      "type": "object",
      "properties": {
        "user_messages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Original user messages that initiated this request"
        },
        "referenced_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files referenced during initial discussion"
        },
        "decisions_made": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "decision": { "type": "string" },
              "rationale": { "type": "string" }
            }
          },
          "description": "Decisions already made during initial discussion"
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the request was created"
    }
  },
  "examples": [
    {
      "feature_name": "storage-service",
      "description": "Artifact storage service with versioning, retention policies, and CDN distribution",
      "problem_statement": "Users need a way to store and manage artifacts (files, binaries, documents) with proper lifecycle management, access control, and fast global distribution. Currently there is no centralized storage abstraction.",
      "requested_by": "user",
      "priority": "high",
      "target_users": ["platform-developers", "end-users"],
      "success_criteria": [
        "Users can upload artifacts up to 5GB",
        "Artifacts are accessible globally with < 100ms latency",
        "Retention policies automatically clean up old artifacts"
      ],
      "constraints": {
        "technical": ["Must use GCS as backend", "Must integrate with existing auth"]
      },
      "related_features": ["authorization-sharing-system", "platform-subdomains"],
      "timestamp": "2025-12-27T09:00:00Z"
    }
  ]
}
