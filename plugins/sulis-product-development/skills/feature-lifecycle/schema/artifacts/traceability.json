{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-traceability",
  "title": "TRACEABILITY.jsonld Artifact Schema",
  "description": "Required structure for JSON-LD traceability document",
  "type": "object",
  "required": ["structure", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "traceability"
    },
    "file_pattern": {
      "type": "string",
      "const": "TRACEABILITY.jsonld"
    },
    "structure": {
      "type": "object",
      "required": ["context", "feature", "artifacts", "traces"],
      "properties": {
        "context": {
          "type": "object",
          "required": ["@context"],
          "properties": {
            "@context": {
              "type": "object",
              "description": "JSON-LD context with vocabulary definitions"
            }
          }
        },
        "feature": {
          "type": "object",
          "required": ["@id", "@type", "name", "status"],
          "properties": {
            "@id": {
              "type": "string",
              "description": "Feature URI identifier"
            },
            "@type": {
              "type": "string",
              "const": "Feature"
            },
            "name": {
              "type": "string",
              "description": "Feature name"
            },
            "status": {
              "type": "string",
              "enum": ["design", "implementation", "release", "complete"]
            },
            "version": {
              "type": "string"
            }
          }
        },
        "artifacts": {
          "type": "object",
          "required": ["pr_faq", "user_guide", "test_scenarios", "design", "ivs"],
          "properties": {
            "pr_faq": { "$ref": "#/$defs/artifact_reference" },
            "user_guide": { "$ref": "#/$defs/artifact_reference" },
            "test_scenarios": { "$ref": "#/$defs/artifact_reference" },
            "design": { "$ref": "#/$defs/artifact_reference" },
            "ivs": { "$ref": "#/$defs/artifact_reference" },
            "plan": { "$ref": "#/$defs/artifact_reference" },
            "tasks": { "$ref": "#/$defs/artifact_reference" },
            "changelog": { "$ref": "#/$defs/artifact_reference" }
          }
        },
        "traces": {
          "type": "object",
          "required": ["user_guide_to_tests", "design_to_code"],
          "properties": {
            "user_guide_to_tests": {
              "type": "array",
              "items": { "$ref": "#/$defs/trace_link" },
              "description": "Links from User Guide sections to test scenarios"
            },
            "design_to_code": {
              "type": "array",
              "items": { "$ref": "#/$defs/trace_link" },
              "description": "Links from Design components to code files"
            },
            "ivs_to_tests": {
              "type": "array",
              "items": { "$ref": "#/$defs/trace_link" },
              "description": "Links from IVS requirements to verification tests"
            },
            "test_to_code": {
              "type": "array",
              "items": { "$ref": "#/$defs/trace_link" },
              "description": "Links from test scenarios to implementation code"
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "valid_jsonld": {
          "type": "boolean",
          "const": true,
          "description": "Must be valid JSON-LD"
        },
        "all_artifacts_linked": {
          "type": "boolean",
          "const": true,
          "description": "All artifacts must be linked"
        },
        "bidirectional_traces": {
          "type": "boolean",
          "default": true,
          "description": "Traces should be bidirectional where applicable"
        }
      }
    },
    "$defs": {
      "artifact_reference": {
        "type": "object",
        "required": ["@id", "path"],
        "properties": {
          "@id": {
            "type": "string",
            "description": "Artifact URI identifier"
          },
          "@type": {
            "type": "string",
            "enum": ["Document", "Specification", "Code"]
          },
          "path": {
            "type": "string",
            "description": "File path relative to feature directory"
          },
          "hash": {
            "type": "string",
            "description": "Content hash for change detection"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "modified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "trace_link": {
        "type": "object",
        "required": ["source", "target", "type"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Source artifact/section reference"
          },
          "target": {
            "type": "string",
            "description": "Target artifact/section reference"
          },
          "type": {
            "type": "string",
            "enum": ["derives", "implements", "verifies", "documents"],
            "description": "Type of trace relationship"
          },
          "description": {
            "type": "string",
            "description": "Optional description of the link"
          }
        }
      }
    }
  }
}
