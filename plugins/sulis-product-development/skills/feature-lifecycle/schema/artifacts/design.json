{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-design",
  "title": "DESIGN.md Artifact Schema",
  "description": "Required sections and content for Technical Design document",
  "type": "object",
  "required": ["sections", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "design"
    },
    "file_pattern": {
      "type": "string",
      "const": "DESIGN.md"
    },
    "sections": {
      "type": "object",
      "required": ["overview", "requirements", "architecture", "data_model", "api_contracts", "security", "test_summary"],
      "properties": {
        "overview": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["purpose", "scope", "background"],
              "properties": {
                "purpose": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What this design achieves" }
                  }
                },
                "scope": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "In scope and out of scope" }
                  }
                },
                "background": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Context and prior work" }
                  }
                },
                "stakeholders": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Who is affected by this design" }
                  }
                }
              }
            }
          }
        },
        "requirements": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["functional", "non_functional"],
              "properties": {
                "functional": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What the system must do" },
                    "uses_moscow": { "type": "boolean", "default": true }
                  }
                },
                "non_functional": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Performance, security, scalability requirements" }
                  }
                },
                "constraints": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Technical or business constraints" }
                  }
                },
                "assumptions": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Assumptions made during design" }
                  }
                }
              }
            }
          }
        },
        "architecture": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["overview_diagram", "components", "interactions"],
              "properties": {
                "overview_diagram": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "High-level architecture diagram (Mermaid)" },
                    "format": { "type": "string", "const": "mermaid" }
                  }
                },
                "components": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Description of each component" }
                  }
                },
                "interactions": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "How components interact" }
                  }
                },
                "sequence_diagrams": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Sequence diagrams for key flows (Mermaid)" }
                  }
                }
              }
            }
          }
        },
        "data_model": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["entities", "relationships"],
              "properties": {
                "entities": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Entity definitions with attributes" }
                  }
                },
                "relationships": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Entity relationships (ERD if applicable)" }
                  }
                },
                "state_machines": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "State machines for workflow entities" }
                  }
                },
                "validation_rules": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Data validation rules" }
                  }
                }
              }
            }
          }
        },
        "api_contracts": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["endpoints"],
              "properties": {
                "endpoints": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "API endpoint specifications" },
                    "follows_conventions": { "type": "boolean", "default": true }
                  }
                },
                "request_response": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Request/response schemas" }
                  }
                },
                "error_catalog": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Error codes and their meanings" }
                  }
                }
              }
            }
          }
        },
        "security": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["authentication", "authorization"],
              "properties": {
                "authentication": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "How users are authenticated" }
                  }
                },
                "authorization": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Permission model and access control" }
                  }
                },
                "data_protection": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "How data is protected" }
                  }
                },
                "threat_model": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Potential threats and mitigations" }
                  }
                }
              }
            }
          }
        },
        "test_summary": {
          "type": "object",
          "required": ["present", "references_test_scenarios"],
          "properties": {
            "present": { "type": "boolean" },
            "references_test_scenarios": {
              "type": "boolean",
              "const": true,
              "description": "Must reference TEST_SCENARIOS.md"
            },
            "description": { "type": "string", "const": "Summary of test coverage from TEST_SCENARIOS.md" }
          }
        },
        "risks": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Identified risks and mitigation strategies" }
          }
        },
        "alternatives_considered": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Alternative approaches that were considered" }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "min_total_length": {
          "type": "integer",
          "default": 5000,
          "description": "Minimum total document length in characters"
        },
        "has_diagrams": {
          "type": "boolean",
          "const": true,
          "description": "Must include Mermaid diagrams"
        },
        "follows_conventions": {
          "type": "boolean",
          "const": true,
          "description": "Follows PLATFORM_CONVENTIONS.md"
        },
        "architecture_compliant": {
          "type": "boolean",
          "const": true,
          "description": "Compliant with architecture/ARCHITECTURE.md"
        }
      }
    }
  }
}
