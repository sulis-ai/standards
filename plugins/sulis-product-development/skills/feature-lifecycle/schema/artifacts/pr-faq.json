{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-pr-faq",
  "title": "PR_FAQ.md Artifact Schema",
  "description": "Required sections and content for Press Release + FAQ document",
  "type": "object",
  "required": ["sections", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "pr_faq"
    },
    "file_pattern": {
      "type": "string",
      "const": "PR_FAQ.md"
    },
    "sections": {
      "type": "object",
      "required": ["press_release", "faq"],
      "properties": {
        "press_release": {
          "type": "object",
          "required": ["headline", "subheadline", "problem", "solution", "quote", "getting_started", "customer_quote"],
          "properties": {
            "headline": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "Attention-grabbing headline announcing the feature" },
                "min_length": { "type": "integer", "default": 10 },
                "max_length": { "type": "integer", "default": 100 }
              }
            },
            "subheadline": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "One-sentence summary of the value proposition" }
              }
            },
            "problem": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "Clear statement of the problem being solved" },
                "min_length": { "type": "integer", "default": 100 }
              }
            },
            "solution": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "How the feature solves the problem" },
                "min_length": { "type": "integer", "default": 100 }
              }
            },
            "quote": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "Internal stakeholder quote about the feature" }
              }
            },
            "getting_started": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "How users can start using the feature" }
              }
            },
            "customer_quote": {
              "type": "object",
              "required": ["present", "description"],
              "properties": {
                "present": { "type": "boolean" },
                "description": { "type": "string", "const": "Fictional customer quote about the value" }
              }
            }
          }
        },
        "faq": {
          "type": "object",
          "required": ["customer_faq", "internal_faq"],
          "properties": {
            "customer_faq": {
              "type": "object",
              "required": ["present", "min_questions"],
              "properties": {
                "present": { "type": "boolean" },
                "min_questions": { "type": "integer", "default": 5 },
                "description": { "type": "string", "const": "Questions customers would ask about the feature" }
              }
            },
            "internal_faq": {
              "type": "object",
              "required": ["present", "min_questions"],
              "properties": {
                "present": { "type": "boolean" },
                "min_questions": { "type": "integer", "default": 5 },
                "description": { "type": "string", "const": "Internal technical/business questions" }
              }
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "min_total_length": {
          "type": "integer",
          "default": 2000,
          "description": "Minimum total document length in characters"
        },
        "customer_focus": {
          "type": "boolean",
          "const": true,
          "description": "Must be written from customer perspective"
        },
        "no_technical_jargon": {
          "type": "boolean",
          "default": true,
          "description": "Avoid technical jargon in press release section"
        }
      }
    }
  }
}
