{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-changelog",
  "title": "CHANGELOG.md Artifact Schema",
  "description": "Required sections and content for Changelog document",
  "type": "object",
  "required": ["sections", "entry_format", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "changelog"
    },
    "file_pattern": {
      "type": "string",
      "const": "CHANGELOG.md"
    },
    "sections": {
      "type": "object",
      "required": ["header", "versions"],
      "properties": {
        "header": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "title": { "type": "string", "const": "# Changelog" },
            "description": { "type": "string", "const": "Brief description of what this changelog tracks" },
            "format_reference": {
              "type": "string",
              "const": "https://keepachangelog.com/en/1.0.0/"
            }
          }
        },
        "versions": {
          "type": "object",
          "required": ["present", "has_unreleased"],
          "properties": {
            "present": { "type": "boolean" },
            "has_unreleased": { "type": "boolean" },
            "description": { "type": "string", "const": "Version entries in reverse chronological order" }
          }
        }
      }
    },
    "entry_format": {
      "type": "object",
      "description": "Format for changelog entries",
      "required": ["version_header", "categories"],
      "properties": {
        "version_header": {
          "type": "object",
          "required": ["format"],
          "properties": {
            "format": {
              "type": "string",
              "const": "## [X.Y.Z] - YYYY-MM-DD"
            },
            "unreleased_format": {
              "type": "string",
              "const": "## [Unreleased]"
            }
          }
        },
        "categories": {
          "type": "object",
          "description": "Change categories per Keep a Changelog",
          "properties": {
            "Added": {
              "type": "string",
              "const": "New features"
            },
            "Changed": {
              "type": "string",
              "const": "Changes in existing functionality"
            },
            "Deprecated": {
              "type": "string",
              "const": "Soon-to-be removed features"
            },
            "Removed": {
              "type": "string",
              "const": "Now removed features"
            },
            "Fixed": {
              "type": "string",
              "const": "Bug fixes"
            },
            "Security": {
              "type": "string",
              "const": "Vulnerability fixes"
            }
          }
        },
        "entry_format": {
          "type": "object",
          "properties": {
            "bullet": { "type": "string", "const": "-" },
            "description_required": { "type": "boolean", "const": true },
            "reference_optional": { "type": "boolean", "const": true },
            "example": { "type": "string", "const": "- Add sharing grant repository with Firestore implementation" }
          }
        }
      }
    },
    "semantic_versioning": {
      "type": "object",
      "description": "Semantic versioning rules",
      "properties": {
        "major": {
          "type": "string",
          "const": "Breaking changes"
        },
        "minor": {
          "type": "string",
          "const": "New features (backwards compatible)"
        },
        "patch": {
          "type": "string",
          "const": "Bug fixes (backwards compatible)"
        },
        "initial_version": {
          "type": "string",
          "const": "1.0.0"
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "follows_keepachangelog": {
          "type": "boolean",
          "const": true,
          "description": "Must follow Keep a Changelog format"
        },
        "uses_semver": {
          "type": "boolean",
          "const": true,
          "description": "Must use semantic versioning"
        },
        "has_unreleased_section": {
          "type": "boolean",
          "const": true,
          "description": "Must have [Unreleased] section during development"
        },
        "reverse_chronological": {
          "type": "boolean",
          "const": true,
          "description": "Versions must be in reverse chronological order"
        }
      }
    }
  }
}
