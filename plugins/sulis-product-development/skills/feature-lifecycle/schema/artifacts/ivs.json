{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-ivs",
  "title": "IVS.md Artifact Schema",
  "description": "Required sections and content for Implementation & Verification Specification",
  "type": "object",
  "required": ["sections", "verification_requirements", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "ivs"
    },
    "file_pattern": {
      "type": "string",
      "const": "IVS.md"
    },
    "sections": {
      "type": "object",
      "required": ["infrastructure", "port_mapping", "verification", "production_guardian"],
      "properties": {
        "infrastructure": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["gcp_services"],
              "properties": {
                "gcp_services": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "GCP services used and their configuration" }
                  }
                },
                "iam_permissions": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Required IAM roles and permissions" }
                  }
                },
                "terraform_resources": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Terraform resources to be created" }
                  }
                },
                "environment_variables": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Required environment variables" }
                  }
                }
              }
            }
          }
        },
        "port_mapping": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Mapping from domain ports to infrastructure implementations" },
            "includes_error_mapping": { "type": "boolean", "default": true },
            "includes_retry_policy": { "type": "boolean", "default": true }
          }
        },
        "verification": {
          "type": "object",
          "required": ["present", "has_security", "has_observability", "has_reliability"],
          "properties": {
            "present": { "type": "boolean" },
            "has_security": { "type": "boolean" },
            "has_observability": { "type": "boolean" },
            "has_reliability": { "type": "boolean" }
          }
        },
        "production_guardian": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Checklist for Production Guardian review" }
          }
        },
        "implementation_status": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Status of each component (Complete/Partial/Stub)" }
          }
        }
      }
    },
    "verification_requirements": {
      "type": "object",
      "required": ["security", "observability", "reliability"],
      "properties": {
        "security": {
          "type": "object",
          "required": ["requirements"],
          "properties": {
            "requirements": {
              "type": "array",
              "items": { "$ref": "#/$defs/verification_requirement" },
              "minItems": 1
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["SEC-AUTH", "SEC-AUTHZ", "SEC-DATA", "SEC-INJECT", "SEC-AUDIT"]
              }
            }
          }
        },
        "observability": {
          "type": "object",
          "required": ["requirements"],
          "properties": {
            "requirements": {
              "type": "array",
              "items": { "$ref": "#/$defs/verification_requirement" },
              "minItems": 1
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["OBS-LOG", "OBS-MET", "OBS-TRC", "OBS-ALT"]
              }
            }
          }
        },
        "reliability": {
          "type": "object",
          "required": ["requirements"],
          "properties": {
            "requirements": {
              "type": "array",
              "items": { "$ref": "#/$defs/verification_requirement" },
              "minItems": 1
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["REL-ERR", "REL-RET", "REL-TIMEOUT", "REL-CIRCUIT", "REL-IDEMPOTENT"]
              }
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "min_security_requirements": {
          "type": "integer",
          "default": 2,
          "description": "Minimum SEC-* requirements"
        },
        "min_observability_requirements": {
          "type": "integer",
          "default": 2,
          "description": "Minimum OBS-* requirements"
        },
        "min_reliability_requirements": {
          "type": "integer",
          "default": 2,
          "description": "Minimum REL-* requirements"
        },
        "all_requirements_have_test_ref": {
          "type": "boolean",
          "const": true,
          "description": "Each requirement must reference a test"
        }
      }
    },
    "$defs": {
      "verification_requirement": {
        "type": "object",
        "required": ["id", "description", "verification_method", "test_reference"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(SEC|OBS|REL)-[A-Z]+-\\d{2}$",
            "description": "Unique requirement ID"
          },
          "description": {
            "type": "string",
            "description": "What must be verified"
          },
          "verification_method": {
            "type": "string",
            "enum": ["code_review", "automated_test", "manual_test", "static_analysis", "runtime_check"],
            "description": "How this will be verified"
          },
          "test_reference": {
            "type": "string",
            "description": "Reference to test file/scenario"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "verified", "not_applicable"],
            "default": "pending"
          },
          "evidence": {
            "type": "string",
            "description": "Evidence of verification"
          }
        }
      }
    }
  }
}
