{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-user-guide",
  "title": "USER_GUIDE.md Artifact Schema",
  "description": "Required sections and content for User Guide document",
  "type": "object",
  "required": ["sections", "validation"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "user_guide"
    },
    "file_pattern": {
      "type": "string",
      "const": "USER_GUIDE.md"
    },
    "sections": {
      "type": "object",
      "required": ["overview", "getting_started", "how_to", "reference", "faq"],
      "properties": {
        "overview": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["purpose", "key_concepts"],
              "properties": {
                "purpose": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What this feature does and why it exists" }
                  }
                },
                "key_concepts": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Core concepts users need to understand" }
                  }
                },
                "prerequisites": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "What users need before starting" }
                  }
                }
              }
            }
          }
        },
        "getting_started": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "required": ["quickstart", "first_steps"],
              "properties": {
                "quickstart": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Fastest path to first success (< 5 minutes)" },
                    "has_code_example": { "type": "boolean", "default": true }
                  }
                },
                "first_steps": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Step-by-step guide for new users" }
                  }
                }
              }
            }
          }
        },
        "how_to": {
          "type": "object",
          "required": ["present", "min_guides"],
          "properties": {
            "present": { "type": "boolean" },
            "min_guides": { "type": "integer", "default": 3 },
            "description": { "type": "string", "const": "Task-oriented guides for common use cases" },
            "guides": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["title", "has_steps"],
                "properties": {
                  "title": { "type": "string" },
                  "has_steps": { "type": "boolean" },
                  "has_code_example": { "type": "boolean" }
                }
              }
            }
          }
        },
        "reference": {
          "type": "object",
          "required": ["present", "subsections"],
          "properties": {
            "present": { "type": "boolean" },
            "subsections": {
              "type": "object",
              "properties": {
                "api_reference": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Complete API documentation" },
                    "includes_endpoints": { "type": "boolean" },
                    "includes_request_response": { "type": "boolean" }
                  }
                },
                "configuration": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Configuration options and their effects" }
                  }
                },
                "error_codes": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Error codes and their meanings" }
                  }
                },
                "permissions": {
                  "type": "object",
                  "properties": {
                    "present": { "type": "boolean" },
                    "description": { "type": "string", "const": "Required permissions for each operation" }
                  }
                }
              }
            }
          }
        },
        "faq": {
          "type": "object",
          "required": ["present", "min_questions"],
          "properties": {
            "present": { "type": "boolean" },
            "min_questions": { "type": "integer", "default": 5 },
            "description": { "type": "string", "const": "Frequently asked questions from user perspective" },
            "categories": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["general", "security", "performance", "troubleshooting", "integration"]
              }
            }
          }
        },
        "troubleshooting": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "description": { "type": "string", "const": "Common issues and their solutions" },
            "min_issues": { "type": "integer", "default": 3 }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "min_total_length": {
          "type": "integer",
          "default": 3000,
          "description": "Minimum total document length in characters"
        },
        "user_focused": {
          "type": "boolean",
          "const": true,
          "description": "Written from user perspective, not developer"
        },
        "has_code_examples": {
          "type": "boolean",
          "default": true,
          "description": "Includes practical code examples"
        },
        "follows_conventions": {
          "type": "boolean",
          "default": true,
          "description": "Follows PLATFORM_CONVENTIONS.md naming"
        }
      }
    },
    "test_scenario_derivation": {
      "type": "object",
      "description": "How test scenarios are derived from this guide",
      "properties": {
        "getting_started_to_happy_path": {
          "type": "string",
          "const": "Getting Started section → Happy Path tests (TS-HP-*)"
        },
        "how_to_to_alternate_path": {
          "type": "string",
          "const": "How-To guides → Alternate Path tests (TS-ALT-*)"
        },
        "faq_to_edge_cases": {
          "type": "string",
          "const": "FAQ section → Edge Case tests (TS-*)"
        },
        "reference_to_security": {
          "type": "string",
          "const": "Reference/Permissions → Security tests (TS-SEC-*)"
        }
      }
    }
  }
}
