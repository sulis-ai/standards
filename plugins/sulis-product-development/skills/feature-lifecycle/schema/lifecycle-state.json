{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feature-lifecycle-state",
  "title": "Feature Lifecycle State",
  "description": "Per-feature instance tracking progress through the lifecycle phases",
  "type": "object",
  "required": ["feature_name", "classification", "current_phase", "phases", "created_at"],
  "properties": {
    "feature_name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Kebab-case feature identifier"
    },
    "classification": {
      "type": "string",
      "enum": [
        "service",
        "service_enhancement",
        "extension",
        "extension_enhancement",
        "capability",
        "capability_enhancement",
        "infrastructure"
      ],
      "description": "Feature classification determining required artifacts and permanent location"
    },
    "enhances": {
      "type": ["object", "null"],
      "description": "Parent spec info (required for *_enhancement classifications)",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["service", "extension", "capability"],
          "description": "Type of parent being enhanced"
        },
        "name": {
          "type": "string",
          "description": "Name of parent (e.g., 'compute')"
        },
        "path": {
          "type": "string",
          "description": "Path to parent spec directory (e.g., 'features/services/compute/')"
        },
        "version_at_start": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Parent spec version when enhancement started"
        },
        "version_at_merge": {
          "type": ["string", "null"],
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Parent spec version after delta merged (set at completion)"
        }
      },
      "required": ["type", "name", "path", "version_at_start"]
    },
    "feature_path": {
      "type": "string",
      "pattern": "^\\features/[a-z0-9-]+/$",
      "description": "Path to feature directory"
    },
    "current_phase": {
      "type": "string",
      "enum": ["classification", "design", "implementation", "release", "completion", "complete"],
      "description": "Currently active phase (or 'complete' if finished)"
    },
    "phases": {
      "type": "object",
      "required": ["classification", "design", "implementation", "release", "completion"],
      "properties": {
        "classification": { "$ref": "#/$defs/phase_state" },
        "design": { "$ref": "#/$defs/phase_state" },
        "implementation": { "$ref": "#/$defs/phase_state" },
        "release": { "$ref": "#/$defs/phase_state" },
        "completion": { "$ref": "#/$defs/phase_state" }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Tracks which artifacts have been created for this feature",
      "properties": {
        "pr_faq": { "type": "boolean", "default": false },
        "user_guide": { "type": "boolean", "default": false },
        "test_scenarios": { "type": "boolean", "default": false },
        "design": { "type": "boolean", "default": false },
        "ivs": { "type": "boolean", "default": false },
        "ontology": { "type": "boolean", "default": false },
        "traceability": { "type": "boolean", "default": false },
        "solution_summary": { "type": "boolean", "default": false },
        "entity_model_delta": { "type": "boolean", "default": false, "description": "If feature adds/modifies entities" },
        "service_specification": { "type": "boolean", "default": false, "description": "Required for 'service' classification" },
        "service_specification_delta": { "type": "boolean", "default": false, "description": "Required for 'service_enhancement' classification" },
        "extension_specification": { "type": "boolean", "default": false, "description": "Required for 'extension' classification" },
        "extension_specification_delta": { "type": "boolean", "default": false, "description": "Required for 'extension_enhancement' classification" },
        "capability_specification": { "type": "boolean", "default": false, "description": "Required for 'capability' classification" },
        "capability_specification_delta": { "type": "boolean", "default": false, "description": "Required for 'capability_enhancement' classification" },
        "plan": { "type": "boolean", "default": false },
        "tasks": { "type": "boolean", "default": false },
        "changelog": { "type": "boolean", "default": false }
      }
    },
    "notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/note" },
      "default": [],
      "description": "Session notes and important discoveries"
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocker" },
      "default": [],
      "description": "Current blockers preventing progress"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this feature was initiated"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When this feature was completed (null if in progress)"
    },
    "template_version": {
      "type": "string",
      "default": "1.0.0",
      "description": "Version of lifecycle template used"
    }
  },
  "$defs": {
    "phase_state": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "complete", "blocked"],
          "description": "Current status of this phase (NO DEFERRALS ALLOWED)"
        },
        "started_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this phase started"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this phase completed"
        },
        "input": {
          "type": ["object", "null"],
          "description": "Input data for this phase (validated against input_contract)"
        },
        "output": {
          "type": ["object", "null"],
          "description": "Output data from this phase (validated against output_contract)"
        },
        "gate": {
          "type": ["object", "null"],
          "properties": {
            "passed": {
              "type": "boolean",
              "description": "Whether the gate passed"
            },
            "passed_at": {
              "type": ["string", "null"],
              "format": "date-time"
            },
            "checks": {
              "type": "object",
              "additionalProperties": {
                "type": "boolean"
              },
              "description": "Individual gate check results"
            },
            "approval": {
              "type": ["object", "null"],
              "properties": {
                "approved": { "type": "boolean" },
                "approved_by": { "type": "string" },
                "approved_at": { "type": "string", "format": "date-time" }
              },
              "description": "User approval if required by gate"
            }
          }
        },
        "retries": {
          "type": "integer",
          "default": 0,
          "description": "Number of retry attempts"
        },
        "error": {
          "type": ["string", "null"],
          "description": "Error message if phase failed"
        }
      }
    },
    "note": {
      "type": "object",
      "required": ["timestamp", "content"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "phase": {
          "type": "string",
          "enum": ["design", "implementation", "release", "completion"]
        },
        "content": {
          "type": "string",
          "description": "Note content"
        },
        "type": {
          "type": "string",
          "enum": ["discovery", "decision", "session_end", "session_start", "general"],
          "default": "general"
        }
      }
    },
    "blocker": {
      "type": "object",
      "required": ["id", "phase", "description", "created_at"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique blocker identifier"
        },
        "phase": {
          "type": "string",
          "enum": ["design", "implementation", "release", "completion"]
        },
        "description": {
          "type": "string",
          "description": "What is blocking progress"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolved_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "resolution": {
          "type": ["string", "null"],
          "description": "How it was resolved"
        }
      }
    }
  }
}
